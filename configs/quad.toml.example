# ═══════════════════════════════════════════════════════════════════════════
# QUAD Configuration File — quad.toml
# ═══════════════════════════════════════════════════════════════════════════
#
# Auto-generated by: quad-configure (Claude Code skill)
# Or copy manually:  cp configs/quad.toml.example quad.toml
#
# IMPORTANT:
#   - DO NOT put secrets/API keys here — use .env instead
#   - quad.toml is gitignored; .env.example shows what keys are needed
#   - All values can be overridden by QUAD_* environment variables
#   - Run `quad doctor` to validate this configuration
#
# Quick start:
#   Mock mode (no hardware):  adapter_mode = "mock"
#   Real mode (SDK required): adapter_mode = "real"  +  fill sdk_path below
# ═══════════════════════════════════════════════════════════════════════════

# ── Server / Runtime ──────────────────────────────────────────────────────────

[server]

# "mock" = simulated responses, no SDK or hardware needed (default)
# "real" = invokes actual Qualcomm SDK tools
adapter_mode = "mock"

# Logging
log_level = "info"           # debug | info | warning | error
log_format = "console"       # console | json (use json in production)

# File paths
model_output_dir = "./output"
template_dir = "./templates"

# CPU Fixed Point Mode — execute quantized DLC on CPU without dequantization
# Requires: quantized DLC + CPU runtime. Default: false (CPU uses float32)
# Set true for performance improvement with quantized CPU models.
enable_cpu_fxp = false

# Default power mode for orchestration
# performance = max NPU, lowest latency
# balanced    = mix of NPU + CPU, good latency and power
# efficiency  = minimize power, CPU-first
default_power_mode = "balanced"


# ── SDK Adapters ──────────────────────────────────────────────────────────────

# QAIRT / SNPE — primary inference SDK
# Download from: https://softwarecenter.qualcomm.com
# Version: 2.45.0.260326 (or later)
# After installing, run: source qairt/2.45.0.260326/bin/envsetup.sh
[adapters.qairt]
sdk_path = ""          # e.g. "/path/to/qairt/2.45.0.260326"
version = "2.45.0"

# QNN SDK — included in QAIRT package
[adapters.qnn]
sdk_path = ""          # Usually same as adapters.qairt.sdk_path
target_arch = ""       # e.g. "aarch64-windows" or auto-detect

# SNPE runtime
[adapters.snpe]
sdk_path = ""          # Usually same as adapters.qairt.sdk_path

# Hexagon SDK — for custom DSP kernel development (optional)
# Required only for UDO compilation on DSP targets
[adapters.hexagon]
sdk_path = ""          # e.g. "/path/to/hexagon-sdk"
tools_path = ""        # e.g. "/path/to/hexagon-sdk/tools/HEXAGON_Tools/8.x"

# Adreno GPU SDK (optional)
[adapters.adreno]
sdk_path = ""

# Qualcomm AI Hub — cloud profiling and model benchmarking
# API key goes in .env as QAI_HUB_API_KEY (never here)
[adapters.ai_hub]
api_key_env = "QAI_HUB_API_KEY"
base_url = "https://app.aihub.qualcomm.com/api/v1"


# ── DSP / HTP Runtime ─────────────────────────────────────────────────────────

[dsp]

# Hexagon DSP version for your target device
# v65/v66 (older DSP) | v68/v69/v73/v75/v79 (HTP)
# Common: v73=Snapdragon 8 Gen 2, v75=8 Gen 3/X Elite, v79=8 Elite
# Run `quad detect` to auto-detect, or see docs/PREREQUISITES.md
hexagon_version = ""

# Directory on the device where skel .so files are deployed
# Set automatically by deploy.sh; override if using custom location
adsp_lib_dir = ""

# Target OS type affects ADSP_LIBRARY_PATH mandatory paths:
# android    → /system/lib/rfsa/adsp;/system/vendor/lib/rfsa/adsp;/dsp
# linux      → same as android
# automotive → /usr/lib/rfsa/adsp;/dsp
target_os = "android"


# ── Platform: Windows (Snapdragon X Elite) ───────────────────────────────────

[platforms.windows]
enabled = false
device_type = "local"     # "local" = this machine is the Windows device
                           # WoS (Windows on Snapdragon): set enabled = true


# ── Platform: Linux (Arduino UNO Q / QCS2210 / Yocto) ───────────────────────

[platforms.linux]
enabled = false
device_type = "remote"    # "local" | "remote" (SSH)

# SSH connection to target device
# For Arduino UNO Q: ssh_host = "192.168.x.x", ssh_user = "root"
# Credentials can also be set in .env as TARGET_IP and TARGET_USER
ssh_host = ""             # e.g. "192.168.1.100" or "arduino-uno-q.local"
ssh_user = "root"
ssh_key = "~/.ssh/id_rsa"

# Destination directory on the target device
deploy_dest = "/tmp/snpeexample"


# ── Platform: Android (Snapdragon 8 Elite) ───────────────────────────────────

[platforms.android]
enabled = false

# ADB device serial — blank to auto-select the connected device
# Can also be set in .env as ANDROID_SERIAL
device_serial = ""
adb_path = "adb"          # Path to adb binary if not in PATH

# Deploy destination on device
deploy_dest = "/data/local/tmp/snpeexample"
