.ruff_cache/

# Environment (secrets — never commit)
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Models (large binaries)
*.onnx
*.dlc
*.bin
!configs/**/*.json

# SDK archives (large — download separately)
*.zip
2.45.1/

# QAIRT / SNPE SDK (large — not committed, install via setup script)
qairt/

