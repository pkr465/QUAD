sdks/

# QUAD runtime state (resolved SDK info, etc.)
.quad/

# Word temp files
~$*

# Local config (contains paths specific to your machine)
quad.toml

# Node (VS Code extension)
plugins/vscode/node_modules/
plugins/vscode/out/

# Output
output/
