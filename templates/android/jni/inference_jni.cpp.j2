// DSP Runtime: Set ADSP_LIBRARY_PATH for DSP/AIP runtimes
//
// IMPORTANT: Must be set before initializing SNPE with DSP runtime.
//
// Rules from SNPE DSP Runtime docs:
//   - Uses semicolons (NOT colons) as separator
//   - Must include /system/lib/rfsa/adsp, /system/vendor/lib/rfsa/adsp, /dsp
//   - nativeLibPath = application.getApplicationInfo().nativeLibraryDir
//
// Note: If using the SNPE Java AAR, this is set automatically.
//       Only required for pure JNI applications without the AAR.
// ═══════════════════════════════════════════════════════════════════════════
bool SetAdspLibraryPath(const std::string& nativeLibPath) {
    std::stringstream path;
    path << nativeLibPath
         << ";/system/lib/rfsa/adsp"
         << ";/system/vendor/lib/rfsa/adsp"
         << ";/dsp";

    int result = setenv("ADSP_LIBRARY_PATH", path.str().c_str(), 1 /* override */);
    if (result == 0) {
        LOGI("ADSP_LIBRARY_PATH set: %s", path.str().c_str());
    } else {
        LOGE("Failed to set ADSP_LIBRARY_PATH");
    }
    return result == 0;
}

