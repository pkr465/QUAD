// QNN TFLite Delegate Inference Application
// Generated by QUAD for model: {{ model_name }}
// Backend: {{ backend | default("HTP") }}
//
// Based on QNN SDK API Review (80-63442-50 Oct 17 2024)
// References: TFLite minimal example + QNN Delegate Tutorial
//
// Pipeline:
//   1. Load model.tflite → build TFLite interpreter
//   2. Register QNN delegate → routes ops to QNN hardware
//   3. Execute inference via standard TFLite Invoke()
//   4. Delete QNN delegate

#include <iostream>
#include <memory>
#include <vector>

#include "tensorflow/lite/interpreter.h"
#include "tensorflow/lite/kernels/register.h"
#include "tensorflow/lite/model.h"
#include "QnnTFLiteDelegate.h"

int main() {
    const std::string model_path = "{{ model_tflite | default('model.tflite') }}";

    // ── Step 1: Load TFLite model and build interpreter ──────────────────────
    auto model = tflite::FlatBufferModel::BuildFromFile(model_path.c_str());
    if (!model) {
        std::cerr << "Failed to load model: " << model_path << std::endl;
        return 1;
    }
    tflite::ops::builtin::BuiltinOpResolver resolver;
    std::unique_ptr<tflite::Interpreter> interpreter;
    tflite::InterpreterBuilder(*model, resolver)(&interpreter);
    if (!interpreter) {
        std::cerr << "Failed to build interpreter" << std::endl;
        return 1;
    }

    // ── Step 2: Register QNN delegate ────────────────────────────────────────
    // QNN delegate routes supported ops to hardware acceleration.
    // Unsupported ops fall back to TFLite CPU execution automatically.
    TfLiteQnnDelegateOptions options = TfLiteQnnDelegateOptionsDefault();
    options.backend_type = kHtpBackend;  // Use HTP (NPU); kCpuBackend / kGpuBackend also valid

    TfLiteDelegate* qnn_delegate = TfLiteQnnDelegateCreate(&options);
    if (!qnn_delegate) {
        std::cerr << "Failed to create QNN delegate" << std::endl;
        return 1;
    }
    if (interpreter->ModifyGraphWithDelegate(qnn_delegate) != kTfLiteOk) {
        std::cerr << "Failed to apply QNN delegate" << std::endl;
        TfLiteQnnDelegateDelete(qnn_delegate);
        return 1;
    }

    // ── Step 3: Execute inference ─────────────────────────────────────────────
    interpreter->AllocateTensors();

    // TODO: populate input tensors
    // float* input = interpreter->typed_input_tensor<float>(0);
    // memcpy(input, your_data.data(), your_data.size() * sizeof(float));

    if (interpreter->Invoke() != kTfLiteOk) {
        std::cerr << "Inference failed" << std::endl;
        TfLiteQnnDelegateDelete(qnn_delegate);
        return 1;
    }
    std::cout << "Inference complete." << std::endl;

    // Read outputs:
    // float* output = interpreter->typed_output_tensor<float>(0);

    // ── Step 4: Delete QNN delegate ───────────────────────────────────────────
    TfLiteQnnDelegateDelete(qnn_delegate);
    return 0;
}
