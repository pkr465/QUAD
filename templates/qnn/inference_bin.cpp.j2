// QNN Inference Application — BIN (context binary cache) format
// Generated by QUAD for model: {{ model_name }}
// Backend: {{ backend | default("HTP") }}
//
// Based on QNN SDK API Review (80-63442-50 Oct 17 2024)
// Pipeline: load backend + system → init log/backend/device → load context binary → execute → free
//
// IMPORTANT: model.bin is backend-specific.
// The backend used here MUST match the backend used when model.bin was saved.
// This pipeline saves considerable initialization time vs the .so pipeline.

#include <dlfcn.h>
#include <fstream>
#include <iostream>
#include <vector>

#include "QnnInterface.h"
#include "QnnBackend.h"
#include "QnnContext.h"
#include "QnnGraph.h"
#include "QnnTensor.h"
#include "QnnLog.h"
#include "System/QnnSystemInterface.h"

// ─────────────────────────────────────────────────────────────────────────────
// Utility: read binary file into a buffer
// ─────────────────────────────────────────────────────────────────────────────
std::vector<uint8_t> readBinaryFile(const std::string& path) {
    std::ifstream file(path, std::ios::binary | std::ios::ate);
    if (!file) throw std::runtime_error("Cannot open: " + path);
    size_t size = file.tellg();
    std::vector<uint8_t> buf(size);
    file.seekg(0);
    file.read(reinterpret_cast<char*>(buf.data()), size);
    return buf;
}

int main() {
    const std::string backend_lib  = "{{ backend_lib | default('libQnnHtp.so') }}";
    const std::string system_lib   = "libQnnSystem.so";
    const std::string model_bin    = "{{ model_bin | default('model.bin') }}";

    // ── Step 1: Load backend library ────────────────────────────────────────
    void* backend_lib_handle = dlopen(backend_lib.c_str(), RTLD_NOW | RTLD_LOCAL);
    if (!backend_lib_handle) {
        std::cerr << "Failed to load backend: " << dlerror() << std::endl;
        return 1;
    }
    auto getProviders = (QnnInterface_GetProvidersFn_t)dlsym(backend_lib_handle,
                                                              "QnnInterface_getProviders");
    const QnnInterface_t** providers = nullptr;
    uint32_t n_providers = 0;
    getProviders(&providers, &n_providers);
    QNN_INTERFACE_VER_TYPE qnn_interface = providers[0]->QNN_INTERFACE_VER_NAME;

    // ── Step 2: Load libQnnSystem.so ────────────────────────────────────────
    // libQnnSystem.so is REQUIRED for loading context binary cache
    void* system_lib_handle = dlopen(system_lib.c_str(), RTLD_NOW | RTLD_LOCAL);
    if (!system_lib_handle) {
        std::cerr << "Failed to load system lib: " << dlerror() << std::endl;
        return 1;
    }
    auto getSysProviders = (QnnSystemInterface_GetProvidersFn_t)dlsym(
        system_lib_handle, "QnnSystemInterface_getProviders");
    const QnnSystemInterface_t** sys_providers = nullptr;
    uint32_t n_sys_providers = 0;
    getSysProviders(&sys_providers, &n_sys_providers);
    QNN_SYSTEM_INTERFACE_VER_TYPE sys_interface = sys_providers[0]->QNN_SYSTEM_INTERFACE_VER_NAME;

    // ── Step 3: Initialize Log, Backend, Device (NO Context_create here) ────
    Qnn_LogHandle_t     log_handle     = nullptr;
    Qnn_BackendHandle_t backend_handle = nullptr;
    Qnn_DeviceHandle_t  device_handle  = nullptr;

    qnn_interface.logCreate(QNN_LOG_LEVEL_WARN, nullptr, &log_handle);
    if (QNN_SUCCESS != qnn_interface.backendCreate(log_handle, nullptr, &backend_handle)) {
        std::cerr << "QnnBackend_create failed" << std::endl;
        return 1;
    }
    if (QNN_SUCCESS != qnn_interface.deviceCreate(log_handle, nullptr, &device_handle)) {
        std::cerr << "QnnDevice_create failed" << std::endl;
        return 1;
    }

    // ── Step 4: Load context binary cache ───────────────────────────────────
    // This replaces compose+finalize from the .so pipeline.
    // Skipping compose/finalize saves considerable time.
    std::vector<uint8_t> bin_buffer = readBinaryFile(model_bin);
    Qnn_ContextHandle_t context_handle = nullptr;
    Qnn_ContextBinarySize_t binary_size = bin_buffer.size();

    if (QNN_SUCCESS != sys_interface.systemContextCreate(&context_handle)) {
        std::cerr << "QnnSystemContext_create failed" << std::endl;
        return 1;
    }
    // Retrieve graph info from binary to know graph count and names
    const QnnSystemContext_BinaryInfo_t* binary_info = nullptr;
    Qnn_ContextBinarySize_t binary_info_size = 0;
    sys_interface.systemContextGetBinaryInfo(context_handle, bin_buffer.data(),
                                              binary_size, &binary_info, &binary_info_size);
    sys_interface.systemContextFree(context_handle);

    // Create context from binary
    if (QNN_SUCCESS != qnn_interface.contextCreateFromBinary(
            backend_handle, device_handle, nullptr,
            bin_buffer.data(), binary_size,
            &context_handle, nullptr)) {
        std::cerr << "QnnContext_createFromBinary failed" << std::endl;
        return 1;
    }

    // Retrieve graph handle (graphs are already finalized in the binary)
    Qnn_GraphHandle_t graph_handle = nullptr;
    qnn_interface.graphRetrieve(context_handle, "{{ graph_name | default('main') }}", &graph_handle);

    // ── Step 5: Execute inference ────────────────────────────────────────────
    // TODO: populate input_tensors
    std::vector<Qnn_Tensor_t> input_tensors;
    std::vector<Qnn_Tensor_t> output_tensors;

    if (QNN_SUCCESS != qnn_interface.graphExecute(
            graph_handle,
            input_tensors.data(),  (uint32_t)input_tensors.size(),
            output_tensors.data(), (uint32_t)output_tensors.size(),
            nullptr, nullptr)) {
        std::cerr << "QnnGraph_execute failed" << std::endl;
        return 1;
    }
    std::cout << "Inference complete (from cached context)." << std::endl;

    // ── Step 6: Free resources ───────────────────────────────────────────────
    qnn_interface.contextFree(context_handle, nullptr);
    qnn_interface.deviceFree(device_handle);
    qnn_interface.backendFree(backend_handle);
    qnn_interface.logFree(log_handle);
    dlclose(system_lib_handle);
    dlclose(backend_lib_handle);
    return 0;
}
