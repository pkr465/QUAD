// QNN Inference Application — {{ model_format | upper }} format
// Generated by QUAD for model: {{ model_name }}
// Backend: {{ backend | default("HTP") }}
//
// Based on QNN SDK API Review (80-63442-50 Oct 17 2024)
// Pipeline: load backend → load model → init env → compose graph → execute → free

#include <dlfcn.h>
#include <iostream>
#include <vector>
#include <cstring>

#include "QnnInterface.h"
#include "QnnBackend.h"
#include "QnnContext.h"
#include "QnnGraph.h"
#include "QnnTensor.h"
#include "QnnLog.h"

// Function pointer type for QnnModel_composeGraphs (from model.so)
typedef Qnn_ErrorHandle_t (*QnnModelComposeFn_t)(
    Qnn_BackendHandle_t,
    QNN_INTERFACE_VER_TYPE*,
    Qnn_ContextHandle_t,
    const QnnGraph_Config_t**,
    uint32_t,
    uint32_t*,
    const char***,
    bool,
    QnnLog_Callback_t,
    QnnLog_Level_t
);

// ─────────────────────────────────────────────────────────────────────────────
// Step 1: Load backend library and get QNN interfaces
// ─────────────────────────────────────────────────────────────────────────────
void* loadBackendLib(const std::string& backend_lib_path,
                     QNN_INTERFACE_VER_TYPE& qnn_interface) {
    void* lib = dlopen(backend_lib_path.c_str(), RTLD_NOW | RTLD_LOCAL);
    if (!lib) {
        std::cerr << "Failed to load backend: " << dlerror() << std::endl;
        return nullptr;
    }

    auto getProviders = (QnnInterface_GetProvidersFn_t)dlsym(lib, "QnnInterface_getProviders");
    if (!getProviders) {
        std::cerr << "QnnInterface_getProviders not found" << std::endl;
        dlclose(lib);
        return nullptr;
    }

    const QnnInterface_t** providers = nullptr;
    uint32_t n_providers = 0;
    if (QNN_SUCCESS != getProviders(&providers, &n_providers) || n_providers == 0) {
        std::cerr << "No QNN interface providers found" << std::endl;
        dlclose(lib);
        return nullptr;
    }
    qnn_interface = providers[0]->QNN_INTERFACE_VER_NAME;
    return lib;
}

// ─────────────────────────────────────────────────────────────────────────────
// Step 2: Load model.so and get QnnModel_composeGraphs
// ─────────────────────────────────────────────────────────────────────────────
QnnModelComposeFn_t loadModelLib(const std::string& model_so_path, void*& model_lib) {
    model_lib = dlopen(model_so_path.c_str(), RTLD_NOW | RTLD_LOCAL);
    if (!model_lib) {
        std::cerr << "Failed to load model: " << dlerror() << std::endl;
        return nullptr;
    }
    auto compose = (QnnModelComposeFn_t)dlsym(model_lib, "QnnModel_composeGraphs");
    if (!compose) {
        std::cerr << "QnnModel_composeGraphs not found in model.so" << std::endl;
        dlclose(model_lib);
        return nullptr;
    }
    return compose;
}

// ─────────────────────────────────────────────────────────────────────────────
// Main: {{ model_format | upper }} inference pipeline
// ─────────────────────────────────────────────────────────────────────────────
int main() {
    const std::string backend_lib = "{{ backend_lib | default('libQnnHtp.so') }}";
    const std::string model_so    = "{{ model_so | default('model.so') }}";

    // ── Step 1: Load backend ────────────────────────────────────────────────
    QNN_INTERFACE_VER_TYPE qnn_interface = {};
    void* backend_lib_handle = loadBackendLib(backend_lib, qnn_interface);
    if (!backend_lib_handle) return 1;

    // ── Step 2: Load model.so ───────────────────────────────────────────────
    void* model_lib_handle = nullptr;
    auto compose_fn = loadModelLib(model_so, model_lib_handle);
    if (!compose_fn) return 1;

    // ── Step 3: Initialize QNN environment ─────────────────────────────────
    Qnn_LogHandle_t    log_handle     = nullptr;
    Qnn_BackendHandle_t backend_handle = nullptr;
    Qnn_DeviceHandle_t  device_handle  = nullptr;
    Qnn_ContextHandle_t context_handle = nullptr;

    // QnnLog can be initialized before QnnBackend
    qnn_interface.logCreate(QNN_LOG_LEVEL_WARN, nullptr, &log_handle);

    if (QNN_SUCCESS != qnn_interface.backendCreate(log_handle, nullptr, &backend_handle)) {
        std::cerr << "QnnBackend_create failed" << std::endl;
        return 1;
    }
    if (QNN_SUCCESS != qnn_interface.deviceCreate(log_handle, nullptr, &device_handle)) {
        std::cerr << "QnnDevice_create failed" << std::endl;
        return 1;
    }
    if (QNN_SUCCESS != qnn_interface.contextCreate(backend_handle, device_handle,
                                                    nullptr, &context_handle)) {
        std::cerr << "QnnContext_create failed" << std::endl;
        return 1;
    }

    // ── Step 4: Compose and finalize graph ──────────────────────────────────
    uint32_t graph_count = 0;
    const char** graph_names = nullptr;
    Qnn_GraphHandle_t* graph_handles = nullptr;

    if (QNN_SUCCESS != compose_fn(backend_handle, &qnn_interface, context_handle,
                                   nullptr, 0, &graph_count, &graph_names, false,
                                   nullptr, QNN_LOG_LEVEL_WARN)) {
        std::cerr << "QnnModel_composeGraphs failed" << std::endl;
        return 1;
    }
    // Retrieve graph handle and finalize
    qnn_interface.graphRetrieve(context_handle, graph_names[0], &graph_handles[0]);
    if (QNN_SUCCESS != qnn_interface.graphFinalize(graph_handles[0], nullptr, nullptr)) {
        std::cerr << "QnnGraph_finalize failed" << std::endl;
        return 1;
    }

    // ── Step 5: Execute inference ────────────────────────────────────────────
    // TODO: populate input_tensors with your data
    std::vector<Qnn_Tensor_t> input_tensors;   // Set from model inputs
    std::vector<Qnn_Tensor_t> output_tensors;  // Allocated for model outputs

    if (QNN_SUCCESS != qnn_interface.graphExecute(
            graph_handles[0],
            input_tensors.data(),  (uint32_t)input_tensors.size(),
            output_tensors.data(), (uint32_t)output_tensors.size(),
            nullptr, nullptr)) {
        std::cerr << "QnnGraph_execute failed" << std::endl;
        return 1;
    }
    std::cout << "Inference complete." << std::endl;

    // ── Step 6: Free resources (reverse order) ──────────────────────────────
    qnn_interface.contextFree(context_handle, nullptr);
    qnn_interface.deviceFree(device_handle);
    qnn_interface.backendFree(backend_handle);
    qnn_interface.logFree(log_handle);
    dlclose(model_lib_handle);
    dlclose(backend_lib_handle);
    return 0;
}
