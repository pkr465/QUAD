Auto-generated by QUAD (Qualcomm Unified Agent for Developers).
SDK: SNPE
Target: {{ platform | default('QCS2210') }}
Model: {{ model_path }}
"""

import numpy as np

try:
    import snpe
except ImportError:
    print("SNPE Python SDK not found. Install from SNPE SDK package.")
    raise


def load_model(dlc_path: str, runtime: str = "dsp") -> "snpe.SNPE":
    """Load SNPE DLC model with specified runtime."""
    runtime_map = {
        "cpu": snpe.Runtime.CPU,
        "gpu": snpe.Runtime.GPU,
        "dsp": snpe.Runtime.DSP,
    }
    container = snpe.DlContainer(dlc_path)
    builder = snpe.SNPEBuilder(container)
    builder.set_runtime(runtime_map.get(runtime, snpe.Runtime.DSP))
    return builder.build()


def prepare_input(input_shape: tuple = (1, 3, 224, 224)) -> np.ndarray:
    """Prepare input tensor."""
    return np.random.randn(*input_shape).astype(np.float32)


def run_inference(model: "snpe.SNPE", input_data: np.ndarray) -> np.ndarray:
    """Execute inference on Hexagon DSP."""
    input_map = {"input:0": input_data}
    output_map = model.execute(input_map)
    return list(output_map.values())[0]


def main() -> None:
    """Main inference pipeline."""
    model_path = "{{ model_path }}"
    runtime = "{{ runtime | default('dsp') }}"

    print(f"Loading model: {model_path} (runtime: {runtime})")
    model = load_model(model_path, runtime)

    input_data = prepare_input()
    output = run_inference(model, input_data)

    top_class = np.argmax(output)
    print(f"Prediction: class {top_class} (score: {output[0][top_class]:.4f})")


if __name__ == "__main__":
    main()
