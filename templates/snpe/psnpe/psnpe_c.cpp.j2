// =============================================================================
// PSNPE C API Application Template
// Generated for model: {{ model_name | default('model') }}
// Execution mode: {{ execution_mode | default('sync') }}
// Runtime: {{ runtime | default('dsp') | upper }}
// Instances: {{ num_instances | default(4) }}
// Batch size: {{ batch_size | default(1) }}
// =============================================================================

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>

#include "PSNPE/PSNPE.h"
#include "PSNPE/BuildConfig.h"
