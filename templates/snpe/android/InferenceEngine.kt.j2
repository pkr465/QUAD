    fun createInputTensor(vararg dimensions: Int): FloatTensor {
        val net = requireNetwork()
        inputTensor?.release()  // Release previous if exists
        inputTensor = net.createFloatTensor(*dimensions)
        return inputTensor!!
    }

    /**
     * Fill the input tensor with float data.
