    fun execute(inputsMap: Map<String, FloatTensor>): Map<String, FloatArray> {
        val net = requireNetwork()

        Log.d(TAG, "Executing inference...")
        val startTime = System.nanoTime()

        // Forward propagate through network
        val outputsMap: Map<String, FloatTensor> = net.execute(inputsMap)

        val elapsedMs = (System.nanoTime() - startTime) / 1_000_000.0
        Log.i(TAG, "Inference complete: %.2f ms".format(elapsedMs))

        // Step 5: Read output tensors
        val results = HashMap<String, FloatArray>()
        for ((name, tensor) in outputsMap) {
            val values = FloatArray(tensor.size)
            tensor.read(values, 0, values.size)
            results[name] = values
            Log.d(TAG, "Output '$name': ${values.size} values")
        }

        // Release output tensors (important for memory in multi-threaded apps)
        for ((_, tensor) in outputsMap) {
            tensor.release()
        }

        return results
    }

    // ═══════════════════════════════════════════════════════════════
    // Step 5: Get Top-K Predictions
