     * @param data Input data array (must match tensor size)
     * @param inputName Name of the input layer (default: first input)
     */
    fun setInput(data: FloatArray, inputName: String? = null): Map<String, FloatTensor> {
        val net = requireNetwork()
        val tensor = inputTensor ?: run {
            // Auto-create tensor based on network input dimensions
            val names = net.inputTensorsNames
            val name = inputName ?: names.iterator().next()
            val shape = net.getInputTensorsShapes()[name]!!
            createInputTensor(*shape)
