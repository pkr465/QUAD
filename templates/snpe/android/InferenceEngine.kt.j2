        // Write data to tensor (batch write for performance)
        tensor.write(data, 0, data.size)

        // Build input map
        val inputMap = HashMap<String, FloatTensor>()
        val name = inputName ?: net.inputTensorsNames.iterator().next()
        inputMap[name] = tensor
        return inputMap
    }

