    /**
     * Get top-K classification results from output probabilities.
     */
    fun getTopK(outputValues: FloatArray, k: Int = 5): List<Pair<Int, Float>> {
        return outputValues.mapIndexed { index, value -> index to value }
            .sortedByDescending { it.second }
            .take(k)
    }

