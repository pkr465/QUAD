    /**
     * Convert Android Bitmap to float array in NHWC format.
     *
     * @param bitmap Source bitmap (any size)
     * @return FloatArray of size [height * width * channels]
     */
    private fun bitmapToFloatArray(bitmap: Bitmap): FloatArray {
        // Resize to model input size
        val resized = Bitmap.createScaledBitmap(bitmap, IMAGE_SIZE, IMAGE_SIZE, true)

        val pixels = IntArray(IMAGE_SIZE * IMAGE_SIZE)
        resized.getPixels(pixels, 0, IMAGE_SIZE, 0, 0, IMAGE_SIZE, IMAGE_SIZE)

        // Convert to float array in NHWC format (Height, Width, Channels)
        val floatArray = FloatArray(IMAGE_SIZE * IMAGE_SIZE * NUM_CHANNELS)

        for (i in pixels.indices) {
            val pixel = pixels[i]
{% if normalization | default('zero_one') == 'minus_one_one' %}
            // Normalize to [-1, 1] (InceptionV3 style)
            floatArray[i * 3 + 0] = ((pixel shr 16 and 0xFF) / 127.5f) - 1.0f  // R
            floatArray[i * 3 + 1] = ((pixel shr 8 and 0xFF) / 127.5f) - 1.0f   // G
            floatArray[i * 3 + 2] = ((pixel and 0xFF) / 127.5f) - 1.0f          // B
{% else %}
            // Normalize to [0, 1] (MobileNet style)
            floatArray[i * 3 + 0] = (pixel shr 16 and 0xFF) / 255.0f  // R
            floatArray[i * 3 + 1] = (pixel shr 8 and 0xFF) / 255.0f   // G
            floatArray[i * 3 + 2] = (pixel and 0xFF) / 255.0f          // B
{% endif %}
        }

        if (resized != bitmap) resized.recycle()
        return floatArray
    }

