# ═══════════════════════════════════════════════════════════════════════════
# SNPE UDO Package — {{ package_name }}
# Top-Level Makefile
#
# Auto-generated by QUAD (Qualcomm Unified Agent for Developers).
# Based on: snpe-udo-package-generator output Makefile structure
#
# Required environment variables (set before invoking):
#   SNPE_ROOT         — Path to SNPE/QAIRT SDK root
#   ANDROID_NDK_ROOT  — Path to Android NDK (for Android targets)
#   HEXAGON_SDK_ROOT  — Path to Hexagon SDK (for DSP targets)
#   CL_LIBRARY_PATH   — Path to OpenCL libraries (for GPU targets)
#
# Usage:
#   make all            — Build all supported targets
#   make cpu_x86        — CPU implementation for x86-64 host
#   make cpu_android    — CPU implementation for Android ARM64
#   make gpu_android    — GPU implementation for Android ARM64 (OpenCL)
#   make dsp            — DSP implementation for device (Hexagon {{ dsp_arch }})
#   make dsp_x86        — DSP for offline cache generation (x86 host)
#   make dsp_aarch64    — DSP for Linux ARM64
#   make reg            — Registration library only (all platforms)
#   make reg_x86        — Registration library for x86-64
#   make reg_android    — Registration library for Android ARM64
#   make clean          — Remove all build artifacts
# ═══════════════════════════════════════════════════════════════════════════

PACKAGE_NAME := {{ package_name }}

# ── Toolchain defaults ────────────────────────────────────────────────────
CXX_HOST       ?= clang++
CXX_ANDROID    ?= $(ANDROID_NDK_ROOT)/toolchains/llvm/prebuilt/linux-x86_64/bin/aarch64-linux-android31-clang++
HEXAGON_CC     ?= $(HEXAGON_SDK_ROOT)/tools/HEXAGON_Tools/8.4.12/Tools/bin/hexagon-clang++
DSP_ARCH       := {{ dsp_arch }}

# ── Directories ───────────────────────────────────────────────────────────
SRC_DIR        := jni/src
INC_DIR        := jni/inc
REG_DIR        := jni/src/reg
CPU_DIR        := jni/src/CPU
GPU_DIR        := jni/src/GPU
DSP_DIR        := jni/src/DSP

LIBS_DIR       := libs
OBJ_DIR        := obj

# ── Output directories per architecture ───────────────────────────────────
X86_LIB_DIR         := $(LIBS_DIR)/x86-64_linux_clang
ANDROID_LIB_DIR     := $(LIBS_DIR)/arm64-v8a
DSP_LIB_DIR         := $(LIBS_DIR)/dsp_$(DSP_ARCH)
DSP_X86_LIB_DIR     := $(LIBS_DIR)/x86-64_linux_clang
DSP_AARCH64_LIB_DIR := $(LIBS_DIR)/aarch64-linux-clang

# ── Common flags ──────────────────────────────────────────────────────────
COMMON_CXXFLAGS := -std=c++17 -fPIC -O2 -Wall -Wextra
COMMON_INCLUDES := -I$(INC_DIR) -I$(SNPE_ROOT)/include/SNPE

# ── SNPE UDO includes ─────────────────────────────────────────────────────
UDO_INCLUDES    := -I$(SNPE_ROOT)/include/SNPE/SnpeUdo

# ── Target-specific flags ─────────────────────────────────────────────────
X86_CXXFLAGS    := $(COMMON_CXXFLAGS) $(COMMON_INCLUDES) $(UDO_INCLUDES) -DPLATFORM_X86
ANDROID_CXXFLAGS := $(COMMON_CXXFLAGS) $(COMMON_INCLUDES) $(UDO_INCLUDES) -DPLATFORM_ANDROID
GPU_CXXFLAGS    := $(ANDROID_CXXFLAGS) -I$(CL_LIBRARY_PATH)/../include -DCL_TARGET_OPENCL_VERSION=200
DSP_CXXFLAGS    := -std=c++17 -fPIC -O2 -mv$(DSP_ARCH) -I$(INC_DIR) \
                   -I$(HEXAGON_SDK_ROOT)/incs -I$(HEXAGON_SDK_ROOT)/incs/stddef \
                   -I$(SNPE_ROOT)/include/SNPE

# ── Linker flags ──────────────────────────────────────────────────────────
X86_LDFLAGS     := -shared -lc
ANDROID_LDFLAGS := -shared -llog
GPU_LDFLAGS     := $(ANDROID_LDFLAGS) -L$(CL_LIBRARY_PATH) -lOpenCL
DSP_LDFLAGS     := -shared -G0

# ── Source files ──────────────────────────────────────────────────────────
REG_SRCS        := $(wildcard $(REG_DIR)/*.cpp)
CPU_SRCS        := $(wildcard $(CPU_DIR)/*.cpp)
GPU_SRCS        := $(wildcard $(GPU_DIR)/*.cpp)
DSP_SRCS        := $(wildcard $(DSP_DIR)/*.cpp)

# ── Library names ─────────────────────────────────────────────────────────
REG_LIB         := lib$(PACKAGE_NAME)Reg.so
CPU_IMPL_LIB    := lib$(PACKAGE_NAME)ImplCpu.so
GPU_IMPL_LIB    := lib$(PACKAGE_NAME)ImplGpu.so
DSP_IMPL_LIB    := lib$(PACKAGE_NAME)ImplDsp.so

# ═══════════════════════════════════════════════════════════════════════════
# Targets
# ═══════════════════════════════════════════════════════════════════════════

.PHONY: all cpu_x86 cpu_android gpu_android dsp dsp_x86 dsp_aarch64 \
        reg reg_x86 reg_android clean

## all — build everything for all supported runtimes
all: reg_x86 reg_android \
{% for rt in supported_runtimes %}
{% if rt.upper() == 'CPU' %}
     cpu_x86 cpu_android \
{% elif rt.upper() == 'GPU' %}
     gpu_android \
{% elif rt.upper() in ('DSP', 'DSP_V68', 'DSP_V65', 'DSP_V66', 'HTP') %}
     dsp dsp_x86 dsp_aarch64 \
{% endif %}
{% endfor %}

# ── Registration Library ──────────────────────────────────────────────────

## reg — build registration library for all platforms
reg: reg_x86 reg_android

## reg_x86 — registration library for x86-64 host
reg_x86: $(X86_LIB_DIR)/$(REG_LIB)

$(X86_LIB_DIR)/$(REG_LIB): $(REG_SRCS)
	@mkdir -p $(X86_LIB_DIR)
	$(CXX_HOST) $(X86_CXXFLAGS) $(X86_LDFLAGS) -o $@ $^

## reg_android — registration library for Android ARM64
reg_android: $(ANDROID_LIB_DIR)/$(REG_LIB)

$(ANDROID_LIB_DIR)/$(REG_LIB): $(REG_SRCS)
	@mkdir -p $(ANDROID_LIB_DIR)
	$(CXX_ANDROID) $(ANDROID_CXXFLAGS) $(ANDROID_LDFLAGS) -o $@ $^

# ── CPU Implementation ────────────────────────────────────────────────────

## cpu_x86 — CPU implementation for x86-64 host (testing/simulation)
cpu_x86: $(X86_LIB_DIR)/$(CPU_IMPL_LIB)

$(X86_LIB_DIR)/$(CPU_IMPL_LIB): $(CPU_SRCS)
	@mkdir -p $(X86_LIB_DIR)
	$(CXX_HOST) $(X86_CXXFLAGS) $(X86_LDFLAGS) -o $@ $^

## cpu_android — CPU implementation for Android ARM64 (on-device)
cpu_android: $(ANDROID_LIB_DIR)/$(CPU_IMPL_LIB)

$(ANDROID_LIB_DIR)/$(CPU_IMPL_LIB): $(CPU_SRCS)
	@mkdir -p $(ANDROID_LIB_DIR)
	$(CXX_ANDROID) $(ANDROID_CXXFLAGS) $(ANDROID_LDFLAGS) -o $@ $^

# ── GPU Implementation (OpenCL) ──────────────────────────────────────────

## gpu_android — GPU implementation for Android ARM64 (requires CL_LIBRARY_PATH)
gpu_android: $(ANDROID_LIB_DIR)/$(GPU_IMPL_LIB)

$(ANDROID_LIB_DIR)/$(GPU_IMPL_LIB): $(GPU_SRCS)
	@mkdir -p $(ANDROID_LIB_DIR)
ifndef CL_LIBRARY_PATH
	$(error CL_LIBRARY_PATH is not set. Set it to the directory containing libOpenCL.so)
endif
ifndef ANDROID_NDK_ROOT
	$(error ANDROID_NDK_ROOT is not set. Required for Android cross-compilation)
endif
	$(CXX_ANDROID) $(GPU_CXXFLAGS) $(GPU_LDFLAGS) -o $@ $^

# ── DSP Implementation (Hexagon) ─────────────────────────────────────────

## dsp — DSP implementation for device (Hexagon {{ dsp_arch }})
dsp: $(DSP_LIB_DIR)/$(DSP_IMPL_LIB)

$(DSP_LIB_DIR)/$(DSP_IMPL_LIB): $(DSP_SRCS)
	@mkdir -p $(DSP_LIB_DIR)
ifndef HEXAGON_SDK_ROOT
	$(error HEXAGON_SDK_ROOT is not set. Required for DSP compilation)
endif
	$(HEXAGON_CC) $(DSP_CXXFLAGS) $(DSP_LDFLAGS) -o $@ $^

## dsp_x86 — DSP for offline cache generation (x86 host simulation)
dsp_x86: $(DSP_X86_LIB_DIR)/$(DSP_IMPL_LIB)

$(DSP_X86_LIB_DIR)/$(DSP_IMPL_LIB): $(DSP_SRCS)
	@mkdir -p $(DSP_X86_LIB_DIR)
	$(CXX_HOST) $(X86_CXXFLAGS) -DTARGET_DSP_SIM $(X86_LDFLAGS) -o $@ $^

## dsp_aarch64 — DSP for Linux ARM64 devices
dsp_aarch64: $(DSP_AARCH64_LIB_DIR)/$(DSP_IMPL_LIB)

$(DSP_AARCH64_LIB_DIR)/$(DSP_IMPL_LIB): $(DSP_SRCS)
	@mkdir -p $(DSP_AARCH64_LIB_DIR)
	$(CXX_ANDROID) $(ANDROID_CXXFLAGS) -DTARGET_DSP $(ANDROID_LDFLAGS) -o $@ $^

# ── Cleanup ───────────────────────────────────────────────────────────────

## clean — remove all build artifacts
clean:
	rm -rf $(LIBS_DIR) $(OBJ_DIR)
	@echo "Cleaned $(PACKAGE_NAME) build artifacts."
