/**
 * QnnOpPackage_validateOpConfig
 *
 * Validate that the op configuration received from the SNPE/QNN graph
 * compiler is compatible with this implementation.
 *
 * Called during model preparation (offline or on-device compilation).
 */
Qnn_ErrorHandle_t
QnnOpPackage_validateOpConfig(Qnn_OpConfigV1_t opConfig) {
    // Expect exactly 1 input and 1 output
    if (opConfig.numOfInputs  != 1) return QNN_OP_PACKAGE_ERROR_VALIDATION_FAILURE;
    if (opConfig.numOfOutputs != 1) return QNN_OP_PACKAGE_ERROR_VALIDATION_FAILURE;

    // Op type must match what was declared in the package XML descriptor
    const char* expected_op = "{{ op_name | default('Softmax') }}";
    if (std::strcmp(opConfig.typeName, expected_op) != 0) {
        return QNN_OP_PACKAGE_ERROR_VALIDATION_FAILURE;
    }

    // Validate data type — HTP quantised path expects UINT8 or INT8
    const Qnn_Tensor_t& inp = opConfig.inputTensors[0];
    if (inp.v1.dataType != QNN_DATATYPE_SFIXED_POINT_8 &&
        inp.v1.dataType != QNN_DATATYPE_UFIXED_POINT_8) {
        // Float32 fallback allowed during simulation/debugging
        if (inp.v1.dataType != QNN_DATATYPE_FLOAT_32) {
            return QNN_OP_PACKAGE_ERROR_VALIDATION_FAILURE;
        }
    }

    return QNN_SUCCESS;
}

