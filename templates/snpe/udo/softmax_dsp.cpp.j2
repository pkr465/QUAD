// ═══════════════════════════════════════════════════════════════════════════
// Quantisation helpers
// ═══════════════════════════════════════════════════════════════════════════

/**
 * Dequantise INT8 to float using affine encoding: f = (q - zero_point) * scale.
 *
 * SNPE/QNN stores quantised tensors as signed or unsigned 8-bit integers.
 * The QnnOpPackage_Tensor_t carries scale and zero_point for each tensor.
 */
static inline float dequant_i8(int8_t q, float scale, int32_t zero_point) {
    return (static_cast<float>(q) - static_cast<float>(zero_point)) * scale;
}

/**
 * Quantise float back to INT8: q = clamp(round(f / scale) + zero_point, -128, 127).
 */
static inline int8_t quant_i8(float f, float scale, int32_t zero_point) {
    float qf = std::round(f / scale) + static_cast<float>(zero_point);
    qf = std::max(qf, -128.0f);
    qf = std::min(qf,  127.0f);
    return static_cast<int8_t>(qf);
}

// ═══════════════════════════════════════════════════════════════════════════
// Core computation — INT8 quantised softmax
// ═══════════════════════════════════════════════════════════════════════════

/**
 * Compute softmax on a quantised NHWC INT8 tensor.
 *
 * The operation is performed in float32 precision after dequantisation.
 * Outputs are requantised using the output tensor's scale / zero_point.
 * For a true HTP-accelerated path, replace this reference implementation
 * with Hexagon NN graph node construction (see HexagonNN SDK examples).
 *
 * @param in_data       Input  INT8 buffer  [N*H*W*C]
 * @param out_data      Output INT8 buffer  [N*H*W*C]
 * @param n, h, w, c    Tensor dimensions (NHWC)
 * @param in_scale      Input  quantisation scale
 * @param in_zp         Input  zero point
 * @param out_scale     Output quantisation scale
 * @param out_zp        Output zero point
 */
static void softmax_nhwc_int8(
        const int8_t* in_data,
        int8_t*       out_data,
        uint32_t n, uint32_t h, uint32_t w, uint32_t c,
        float in_scale,  int32_t in_zp,
        float out_scale, int32_t out_zp) {

    const uint32_t spatial = n * h * w;

    for (uint32_t s = 0; s < spatial; ++s) {
        const int8_t* in_slice  = in_data  + s * c;
        int8_t*       out_slice = out_data + s * c;

        // Step 1 — dequantise slice to float
        float fslice[c];  // VLAs: acceptable on Hexagon toolchain
        for (uint32_t i = 0; i < c; ++i) {
            fslice[i] = dequant_i8(in_slice[i], in_scale, in_zp);
        }

        // Step 2 — numerically stable softmax in float
        float max_val = fslice[0];
        for (uint32_t i = 1; i < c; ++i) {
            if (fslice[i] > max_val) max_val = fslice[i];
        }
        float sum = 0.0f;
        for (uint32_t i = 0; i < c; ++i) {
            fslice[i] = std::exp(fslice[i] - max_val);
            sum += fslice[i];
        }
        float inv_sum = 1.0f / sum;
        for (uint32_t i = 0; i < c; ++i) {
            fslice[i] *= inv_sum;
        }

        // Step 3 — requantise to INT8 output encoding
        for (uint32_t i = 0; i < c; ++i) {
            out_slice[i] = quant_i8(fslice[i], out_scale, out_zp);
        }
    }
}

