/**
 * QnnOpPackage_executeOp
 *
 * Execute the op for one inference iteration.
 *
 * SNPE/QNN calls this function with populated input/output tensor handles.
 * Tensor data pointers and quantisation parameters are read from the
 * QnnOpPackage_Tensor_t structs.
 *
 * @param node   HTP node handle (opaque for reference implementation)
 */
Qnn_ErrorHandle_t
QnnOpPackage_executeOp(QnnHtpOpPackage_Node_t node,
                       QnnHtpOpPackage_GraphInfrastructure_t /* infra */) {
    if (node == nullptr) return QNN_OP_PACKAGE_ERROR_INVALID_ARGUMENT;

    // Recover op config embedded at create time
    // (In a production HTP op, the runtime passes tensor addresses directly
    //  via the node context — see QNN HTP Op Package Porting Guide.)
    const Qnn_OpConfigV1_t* opConfig =
        static_cast<const Qnn_OpConfigV1_t*>(node);

    const Qnn_Tensor_t& qnn_in  = opConfig->inputTensors[0];
    const Qnn_Tensor_t& qnn_out = opConfig->outputTensors[0];

    // ── Unpack dimensions ────────────────────────────────────────────
    uint32_t n = 1, h = 1, w = 1, c = 1;
    const uint32_t rank = qnn_in.v1.rank;
    if (rank == 4) {
        n = qnn_in.v1.dimensions[0];
        h = qnn_in.v1.dimensions[1];
        w = qnn_in.v1.dimensions[2];
        c = qnn_in.v1.dimensions[3];
    } else if (rank == 2) {
        n = qnn_in.v1.dimensions[0];
        c = qnn_in.v1.dimensions[1];
    } else if (rank == 1) {
        c = qnn_in.v1.dimensions[0];
    }

    // ── Unpack quantisation parameters ───────────────────────────────
    const Qnn_QuantizeParams_t& in_qp  = qnn_in.v1.quantizeParams;
    const Qnn_QuantizeParams_t& out_qp = qnn_out.v1.quantizeParams;

    const float   in_scale  = in_qp.scaleOffsetEncoding.scale;
    const int32_t in_zp     = in_qp.scaleOffsetEncoding.offset;
    const float   out_scale = out_qp.scaleOffsetEncoding.scale;
    const int32_t out_zp    = out_qp.scaleOffsetEncoding.offset;

    // ── Dispatch by data type ─────────────────────────────────────────
    const Qnn_DataType_t dtype = qnn_in.v1.dataType;

    if (dtype == QNN_DATATYPE_SFIXED_POINT_8 ||
        dtype == QNN_DATATYPE_UFIXED_POINT_8) {
        // Quantised INT8 path (production)
        const int8_t* in_buf  = static_cast<const int8_t*>(qnn_in.v1.clientBuf.data);
        int8_t*       out_buf = static_cast<int8_t*>(qnn_out.v1.clientBuf.data);
        softmax_nhwc_int8(in_buf, out_buf, n, h, w, c,
                          in_scale, in_zp, out_scale, out_zp);
    } else {
        // Float32 simulation / debug path
        const float* in_buf  = static_cast<const float*>(qnn_in.v1.clientBuf.data);
        float*       out_buf = static_cast<float*>(qnn_out.v1.clientBuf.data);

        // Inline float softmax (same logic as CPU implementation)
        const uint32_t spatial = n * h * w;
        for (uint32_t s = 0; s < spatial; ++s) {
            const float* src = in_buf  + s * c;
            float*       dst = out_buf + s * c;
            float max_v = src[0];
            for (uint32_t i = 1; i < c; ++i) if (src[i] > max_v) max_v = src[i];
            float sum = 0.0f;
            for (uint32_t i = 0; i < c; ++i) { dst[i] = std::exp(src[i] - max_v); sum += dst[i]; }
            float inv = 1.0f / sum;
            for (uint32_t i = 0; i < c; ++i) dst[i] *= inv;
        }
    }

    return QNN_SUCCESS;
}

