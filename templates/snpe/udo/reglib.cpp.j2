/**
 * SnpeUdo_getVersion — return the UDO API version this library was built
 * against.
 *
 * SNPE uses this to verify binary compatibility between the registration
 * library and the runtime.  Return the compile-time constant from UdoBase.h.
 *
 * @param[out] version  Pointer filled with the API version struct.
 * @return SNPE_UDO_NO_ERROR on success.
 */
SnpeUdo_ErrorType_t
SnpeUdo_getVersion(SnpeUdo_LibVersion_t* version) {
    if (version == nullptr) {
        return SNPE_UDO_INVALID_ARGUMENT;
    }

    // SNPE_UDO_API_VERSION_MAJOR/MINOR are defined in SnpeUdo/UdoBase.h
    version->major = SNPE_UDO_API_VERSION_MAJOR;
    version->minor = SNPE_UDO_API_VERSION_MINOR;
    version->teeny = SNPE_UDO_API_VERSION_TEENY;

    return SNPE_UDO_NO_ERROR;
}

/**
 * SnpeUdo_getRegInfo — return package registration metadata.
 *
 * SNPE calls this immediately after loading the registration library to
 * learn:
 *   - Which operator types this package handles
 *   - Which compute cores are supported
 *   - The filenames of per-core implementation libraries
 *
 * The returned pointer must remain valid for the lifetime of the library
 * (static storage is fine).
 *
 * @param[out] regInfo  Pointer-to-pointer filled with the static regInfo.
 * @return SNPE_UDO_NO_ERROR on success.
 */
SnpeUdo_ErrorType_t
SnpeUdo_getRegInfo(SnpeUdo_RegInfo_t** regInfo) {
    if (regInfo == nullptr) {
        return SNPE_UDO_INVALID_ARGUMENT;
    }

    *regInfo = &s_regInfo;
    return SNPE_UDO_NO_ERROR;
}

/**
 * SnpeUdo_validateOperation — validate an operation configuration at
 * network creation (graph compilation) time.
 *
 * SNPE calls this for each instance of a UDO operator encountered when
 * loading a DLC.  The registration library should verify that:
 *   - The opType matches a supported op
 *   - Input / output tensor counts and dtypes are compatible
 *   - Static parameters (if any) are valid
 *
 * Returning an error here causes model loading to fail with a descriptive
 * error rather than crashing at inference time.
 *
 * @param opDefinition  Full op spec including tensor info and parameters.
 * @return SNPE_UDO_NO_ERROR if the config is valid.
 */
SnpeUdo_ErrorType_t
SnpeUdo_validateOperation(SnpeUdo_OpDefinition_t* opDefinition) {
    if (opDefinition == nullptr) {
        return SNPE_UDO_INVALID_ARGUMENT;
    }

    // ── Check operator type ──────────────────────────────────────────
    bool opTypeValid = false;
    for (uint32_t i = 0; i < s_numOps; ++i) {
        if (std::strcmp(opDefinition->opType, s_opTypesList[i]) == 0) {
            opTypeValid = true;
            break;
        }
    }
    if (!opTypeValid) {
        return SNPE_UDO_WRONG_OPERATION;
    }

    // ── Check input/output tensor counts ─────────────────────────────
    // {{ op_name }} expects at least 1 input and 1 output.
    if (opDefinition->numInputs < 1) {
        return SNPE_UDO_WRONG_NUMBER_OF_INPUTS;
    }
    if (opDefinition->numOutputs < 1) {
        return SNPE_UDO_WRONG_NUMBER_OF_OUTPUTS;
    }

    // ── Validate input data types ────────────────────────────────────
    // Accept FLOAT_32 (CPU/GPU) and quantised FIXED_POINT_8 (DSP/HTP).
    for (uint32_t i = 0; i < opDefinition->numInputs; ++i) {
        SnpeUdo_DataType_t dt = opDefinition->inputParams[i].dataType;
        if (dt != SNPE_UDO_DATATYPE_FLOAT_32 &&
            dt != SNPE_UDO_DATATYPE_FLOAT_16 &&
            dt != SNPE_UDO_DATATYPE_FIXED_POINT_8 &&
            dt != SNPE_UDO_DATATYPE_FIXED_POINT_16) {
            return SNPE_UDO_INVALID_DATATYPE;
        }
    }

    // ── Validate output data types ───────────────────────────────────
    for (uint32_t i = 0; i < opDefinition->numOutputs; ++i) {
        SnpeUdo_DataType_t dt = opDefinition->outputParams[i].dataType;
        if (dt != SNPE_UDO_DATATYPE_FLOAT_32 &&
            dt != SNPE_UDO_DATATYPE_FLOAT_16 &&
            dt != SNPE_UDO_DATATYPE_FIXED_POINT_8 &&
            dt != SNPE_UDO_DATATYPE_FIXED_POINT_16) {
            return SNPE_UDO_INVALID_DATATYPE;
        }
    }

    return SNPE_UDO_NO_ERROR;
}

} // extern "C"
