 *
 * Call registerUdoPackage() before this function.
 * The runtime order should include the backend that the UDO targets;
 * SNPE will fall back automatically if the preferred runtime is unavailable.
 *
 * @param application  Android Application context
 * @param modelFile    Path to the .dlc model on-device (must exist)
 * @return             Loaded NeuralNetwork, or null on failure
 */
fun loadNetworkWithUdo(
    application: Application,
    modelFile: File
): NeuralNetwork? {
    if (!modelFile.exists()) {
        Log.e(TAG, "Model file not found: ${modelFile.absolutePath}")
        return null
    }

    return try {
        val network = SNPE.NeuralNetworkBuilder(application)
