/**
 * Check whether the target runtime is available on this device.
 * Uses the SNPE Platform Validator (requires snpe-platform-validator.aar).
 *
 * @param application  Android Application context
 * @param runtime      PlatformValidatorUtil.Runtime value to check
 * @return true if the runtime is supported
 */
fun isRuntimeAvailable(
    application: Application,
    runtime: PlatformValidatorUtil.Runtime = PlatformValidatorUtil.Runtime.DSP
): Boolean {
    return try {
        val validator = PlatformValidator(runtime)
        val available = validator.runtimeCheck(application)
        Log.i(TAG, "Runtime $runtime available: $available")
        available
    } catch (e: Exception) {
        Log.w(TAG, "Platform validator error: ${e.message}")
        false
    }
}
