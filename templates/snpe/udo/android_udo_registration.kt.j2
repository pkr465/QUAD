/**
 * Convenience function: register the UDO package then load the model.
 *
 * Typical usage in LoadNetworkTask.doInBackground():
 *
 *   val network = loadUdoNetwork(application, File(modelPath))
 *   if (network != null) { /* run inference */ }
 *
 * @param application  Android Application context
 * @param modelFile    DLC model file on-device
 * @return             Ready-to-use NeuralNetwork, or null on any error
 */
fun loadUdoNetwork(
    application: Application,
    modelFile: File
): NeuralNetwork? {
    if (!registerUdoPackage(application)) {
        Log.w(TAG, "Proceeding without UDO — op may fall back to built-in impl")
    }
    return loadNetworkWithUdo(application, modelFile)
}

