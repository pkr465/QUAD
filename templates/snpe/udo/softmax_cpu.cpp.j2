/**
 * Apply softmax along the last dimension of a flat NHWC float buffer.
 *
 * For each spatial position (n, h, w) the depth-slice of length C is
 * converted to a probability distribution: exp(x_i) / sum(exp(x_j)).
 *
 * Numerically stable version: subtract max(x) before exponentiation.
 *
 * @param input   Pointer to input  floats, shape [N, H, W, C]
 * @param output  Pointer to output floats, same shape
 * @param n       Batch size
 * @param h       Height
 * @param w       Width
 * @param c       Channels (softmax is applied over this axis)
 */
static void softmax_nhwc(const float* input, float* output,
                         uint32_t n, uint32_t h, uint32_t w, uint32_t c) {
    const uint32_t spatial = n * h * w;
    for (uint32_t s = 0; s < spatial; ++s) {
        const float* in_slice  = input  + s * c;
        float*       out_slice = output + s * c;

        // Step 1 — find max for numerical stability
        float max_val = in_slice[0];
        for (uint32_t i = 1; i < c; ++i) {
            if (in_slice[i] > max_val) max_val = in_slice[i];
        }

        // Step 2 — exponentiate (shifted) and accumulate sum
        float sum = 0.0f;
        for (uint32_t i = 0; i < c; ++i) {
            out_slice[i] = std::exp(in_slice[i] - max_val);
            sum += out_slice[i];
        }

        // Step 3 — normalise
        float inv_sum = 1.0f / sum;
        for (uint32_t i = 0; i < c; ++i) {
            out_slice[i] *= inv_sum;
        }
    }
}

