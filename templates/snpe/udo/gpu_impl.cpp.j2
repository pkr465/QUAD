#pragma OPENCL EXTENSION cl_khr_fp16 : enable

__kernel void {{ op_name | lower }}_kernel(
    __global const half* input,
    __global half*       output,
    const int            num_elements,
    const int            depth)
{
    // Global work-item ID = spatial index (n*h*w position)
    int gid = get_global_id(0);
    int num_spatial = num_elements / depth;

    if (gid >= num_spatial) return;

    int offset = gid * depth;

    // Step 1: Find max for numerical stability (in float32)
    float max_val = vload_half(offset, input);
    for (int i = 1; i < depth; ++i) {
        float val = vload_half(offset + i, input);
        max_val = fmax(max_val, val);
    }

    // Step 2: Compute exp(x - max) and accumulate sum
    float sum = 0.0f;
    for (int i = 0; i < depth; ++i) {
        float val = vload_half(offset + i, input);
        float e = exp(val - max_val);
        sum += e;
    }

    // Step 3: Normalize and write output as half
    float inv_sum = 1.0f / sum;
    for (int i = 0; i < depth; ++i) {
        float val = vload_half(offset + i, input);
        float e = exp(val - max_val);
        float result = e * inv_sum;
        vstore_half(result, offset + i, output);
    }
}
)CL";

