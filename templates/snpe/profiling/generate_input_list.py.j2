#!/usr/bin/env python3
"""Input list generator for snpe-net-run.

snpe-net-run requires a text file (input_list.txt) listing raw binary input files,
one per line. Each line corresponds to one inference pass.

Generated by QUAD for model: {{ model_name }}
Input shape: {{ input_shape }}  (NHWC format)
Input dtype: {{ dtype | default("float32") }}
"""

from __future__ import annotations

import argparse
import struct
from pathlib import Path

import numpy as np


def generate_input_list(
    image_paths: list[str],
    output_dir: str = "inputs",
    input_shape: tuple[int, ...] = {{ input_shape }},
    dtype: str = "{{ dtype | default('float32') }}",
    channel_order: str = "{{ channel_order | default('rgb') }}",
    {% if mean_values is defined -%}
    mean: list[float] = {{ mean_values }},
    {% else -%}
    mean: list[float] | None = None,
    {% endif -%}
    normalize: bool = {{ normalize | default('False') }},
) -> str:
    """Generate raw input files and write input_list.txt.

    Args:
        image_paths: List of image file paths to convert. If empty, generates
                     synthetic random inputs for profiling/benchmarking.
        output_dir:  Directory to write .raw binary files.
        input_shape: Model input shape in NHWC format (N, H, W, C).
        dtype:       numpy dtype string ('float32', 'uint8', etc.)
        channel_order: 'rgb' or 'bgr' — must match model training.
        mean:        Per-channel mean to subtract (in channel_order).
        normalize:   If True, divide by 255 before mean subtraction.

    Returns:
        Path to the generated input_list.txt file.
    """
    output_path = Path(output_dir)
    output_path.mkdir(parents=True, exist_ok=True)

    list_lines: list[str] = []
    n, h, w, c = input_shape

    if not image_paths:
        # Generate synthetic random inputs for profiling
        for i in range(n):
            arr = np.random.rand(h, w, c).astype(np.float32)
            raw_path = output_path / f"input_{i:04d}.raw"
            arr.tofile(raw_path)
            list_lines.append(str(raw_path.resolve()))
    else:
        for idx, img_path in enumerate(image_paths):
            try:
                from PIL import Image
                img = Image.open(img_path).convert("RGB").resize((w, h))
                arr = np.array(img, dtype=np.float32)  # HWC, RGB
            except ImportError:
                arr = np.random.rand(h, w, c).astype(np.float32)

            # Channel reorder
            if channel_order.lower() == "bgr":
                arr = arr[:, :, ::-1]

            # Normalization
            if normalize:
                arr /= 255.0

            # Mean subtraction
            if mean is not None:
                arr -= np.array(mean, dtype=np.float32)

            arr = arr.astype(dtype)
            raw_path = output_path / f"input_{idx:04d}.raw"
            arr.tofile(raw_path)
            list_lines.append(str(raw_path.resolve()))

    list_file = output_path / "input_list.txt"
    list_file.write_text("\n".join(list_lines) + "\n")
    print(f"Generated {len(list_lines)} inputs → {list_file}")
    return str(list_file)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Generate input_list.txt for snpe-net-run")
    parser.add_argument("images", nargs="*", help="Image file paths (empty = synthetic)")
    parser.add_argument("--output_dir", default="inputs", help="Output directory")
    parser.add_argument("--channel_order", default="{{ channel_order | default('rgb') }}")
    parser.add_argument("--normalize", action="store_true")
    args = parser.parse_args()

    path = generate_input_list(
        args.images,
        output_dir=args.output_dir,
        channel_order=args.channel_order,
        normalize=args.normalize,
    )
    print(f"Input list: {path}")
