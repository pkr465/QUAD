#!/usr/bin/env bash
# SNPE HTP Linting Profiling Script
# Generated by QUAD for model: {{ model_name }}
# SoC: {{ htp_soc | default("sm8750") }}
#
# Linting profiling provides cycle-based per-op analysis for HTP backend.
# Cycles cannot be converted to microseconds — use for relative comparisons.
#
# Prerequisites:
#   source activate_qairt.sh  (sets QAIRT_SDK_ROOT and PATH)
#   snpe-net-run, snpe-diagview must be in PATH
#
# Output:
#   linting_output/       - inference outputs
#   SNPEDiag_0.bin        - profiling binary log
#   linting_trace*.json   - chrometrace JSON files (one per HTP subnet)

set -euo pipefail

MODEL_DLC="{{ model_dlc }}"
INPUT_LIST="{{ input_list }}"
OUTPUT_DIR="linting_output"
PERF_PROFILE="{{ perf_profile | default('burst') }}"

echo "=== SNPE HTP Linting Profiler ==="
echo "Model : $MODEL_DLC"
echo "Inputs: $INPUT_LIST"
echo ""

# Step 1: Run inference with linting profiling
echo "[1/3] Running snpe-net-run with --profiling_level linting ..."
snpe-net-run \
  --container "$MODEL_DLC" \
  --input_list "$INPUT_LIST" \
  --output_dir "$OUTPUT_DIR" \
  --use_dsp \
  --perf_profile "$PERF_PROFILE" \
  --profiling_level linting

echo "[1/3] Done. Profiling log: SNPEDiag_0.bin"
echo ""

# Step 2: View profiling output
echo "[2/3] Parsing linting profile with snpe-diagview ..."
snpe-diagview --input_log SNPEDiag_0.bin | tee linting_profile.txt
echo "[2/3] Done. Text report: linting_profile.txt"
echo ""

# Step 3: Export chrometrace
echo "[3/3] Exporting chrometrace JSON ..."
snpe-diagview --input_log SNPEDiag_0.bin --chrometrace --output linting_trace
echo "[3/3] Done. Open linting_trace*.json in chrome://tracing"
echo ""

echo "=== Complete. Key files ==="
echo "  linting_profile.txt  - Human-readable cycle counts per op"
echo "  linting_trace*.json  - Chrome tracing visualization"
echo ""
echo "Tip: Look for ops with low Overlap % — they are bottleneck candidates."
echo "     Sub → Conv, Div → Mul, PReLU → ReLU are common HTP optimizations."
