static Snpe_Runtime_t check_runtime(void) {
    Snpe_DlVersion_Handle_t version = Snpe_Util_GetLibraryVersion();
    printf("SNPE Version: %s\n", Snpe_DlVersion_ToString(version));
    Snpe_DlVersion_Delete(version);

{% if runtime == 'dsp' or runtime == 'npu' %}
    if (Snpe_Util_IsRuntimeAvailable(SNPE_RUNTIME_DSP)) {
        printf("Runtime: DSP (Hexagon)\n");
        return SNPE_RUNTIME_DSP;
    }
{% elif runtime == 'gpu' %}
    if (Snpe_Util_IsRuntimeAvailable(SNPE_RUNTIME_GPU)) {
        printf("Runtime: GPU (Adreno)\n");
        return SNPE_RUNTIME_GPU;
    }
{% elif runtime == 'aip' %}
    if (Snpe_Util_IsRuntimeAvailable(SNPE_RUNTIME_AIP_FIXED8_TF)) {
        printf("Runtime: AIP (HTA+HVX)\n");
        return SNPE_RUNTIME_AIP_FIXED8_TF;
    }
{% endif %}

    printf("Runtime: CPU (fallback)\n");
    return SNPE_RUNTIME_CPU;
}

// ═══════════════════════════════════════════════════════════════════
// Step 2: Load Network (DLC Container)
// ═══════════════════════════════════════════════════════════════════

static Snpe_DlContainer_Handle_t load_container(const char* path) {
    Snpe_DlContainer_Handle_t container = Snpe_DlContainer_Open(path);
    if (!container) {
        fprintf(stderr, "ERROR: Failed to open DLC: %s\n", path);
        exit(EXIT_FAILURE);
    }
    printf("Loaded container: %s\n", path);
    return container;
}

// ═══════════════════════════════════════════════════════════════════
// Step 3: Set Builder Options & Build SNPE
// ═══════════════════════════════════════════════════════════════════

static Snpe_SNPE_Handle_t build_snpe(
    Snpe_DlContainer_Handle_t container,
    Snpe_Runtime_t runtime,
    bool use_user_buffers) {

    // Create runtime list
    Snpe_RuntimeList_Handle_t runtime_list = Snpe_RuntimeList_Create();
    Snpe_RuntimeList_Add(runtime_list, runtime);

    // ── Platform Options (PD type) ──────────────────────────────────────────────
    // SNPE defaults to Unsigned PD (unsignedPD:ON).
    // Signed PD requires customer-signed skel libraries (unsignedPD:OFF).
    // See: isRuntimeAvailable() with RuntimeCheckOption to verify PD type.
{% if pd_type | default('unsigned') == 'signed' or platform_options | default('') %}
    Snpe_PlatformConfig_Handle_t platformConfig = Snpe_PlatformConfig_Create();
{% if pd_type | default('unsigned') == 'signed' %}
    Snpe_PlatformConfig_SetPlatformOptions(platformConfig, "unsignedPD:OFF");
{% elif platform_options | default('') %}
    Snpe_PlatformConfig_SetPlatformOptions(platformConfig, "{{ platform_options }}");
{% else %}
    Snpe_PlatformConfig_SetPlatformOptions(platformConfig, "unsignedPD:ON");
{% endif %}
{% endif %}

    // Build SNPE
    Snpe_SNPEBuilder_Handle_t builder = Snpe_SNPEBuilder_Create(container);
    Snpe_SNPEBuilder_SetRuntimeProcessorOrder(builder, runtime_list);
    Snpe_SNPEBuilder_SetUseUserSuppliedBuffers(builder, use_user_buffers);
{% if pd_type | default('unsigned') == 'signed' or platform_options | default('') %}
    Snpe_SNPEBuilder_SetPlatformConfig(builder, platformConfig);
    Snpe_PlatformConfig_Delete(platformConfig);  // Created by user — must delete
{% endif %}
{% if enable_init_cache | default(false) %}
    Snpe_SNPEBuilder_SetInitCacheMode(builder, true);
{% endif %}

{% if input_dimensions | default({}) %}
    // ── Network Resizing ──────────────────────────────────────────────────
    // Resize network inputs at load time using TensorShapeMap.
    // Allows changing input dimensions (e.g. batch size, resolution)
    // without re-converting the model.
    // See: SNPE Network Resizing documentation.
    Snpe_TensorShapeMap_Handle_t shape_map = Snpe_TensorShapeMap_Create();
{% for name, shape in input_dimensions.items() %}
    {
        size_t dims_{{ loop.index }}[] = { {{ shape | join(', ') }} };
        Snpe_TensorShapeMap_Add(shape_map, "{{ name }}", dims_{{ loop.index }}, {{ shape | length }});
    }
{% endfor %}
    Snpe_SNPEBuilder_SetInputDimensions(builder, shape_map);
    Snpe_TensorShapeMap_Delete(shape_map);  // Returned by value — must delete
{% endif %}

{% if enable_cpu_fxp | default(false) %}
    // ── CPU Fixed Point Mode ────────────────────────────────────────────────
    // Executes quantized DLC on CPU without dequantization.
    // Requires: quantized DLC, CPU runtime, #include "SNPE/SNPEBuilder.h"
    // DSP→CPU fallback will also use FXP (no dequant = perf gain).
    // Note: not all ops support FXP; unsupported fall back to CPU float.
    Snpe_SNPEBuilder_SetCpuFixedPointMode(builder, true);
{% endif %}

    Snpe_SNPE_Handle_t snpe = Snpe_SNPEBuilder_Build(builder);
    if (!snpe) {
        fprintf(stderr, "ERROR: Failed to build SNPE\n");
        exit(EXIT_FAILURE);
    }

    // Cleanup builder resources
    Snpe_SNPEBuilder_Delete(builder);
    Snpe_RuntimeList_Delete(runtime_list);

    return snpe;
}

// ═══════════════════════════════════════════════════════════════════
// Step 4: Load Input (ITensor mode)
// ═══════════════════════════════════════════════════════════════════

static Snpe_TensorMap_Handle_t load_input_tensor(
    Snpe_SNPE_Handle_t snpe,
    const char* input_file) {

    // Get input tensor names
    Snpe_StringList_Handle_t input_names = Snpe_SNPE_GetInputTensorNames(snpe);
    if (!input_names) {
        fprintf(stderr, "ERROR: Failed to get input tensor names\n");
        exit(EXIT_FAILURE);
    }
    assert(Snpe_StringList_Size(input_names) >= 1);

    const char* tensor_name = Snpe_StringList_At(input_names, 0);

    // Get input dimensions
    Snpe_TensorShape_Handle_t input_dims = Snpe_SNPE_GetInputDimensions(snpe, tensor_name);

    // Create ITensor
    Snpe_ITensor_Handle_t input_tensor = Snpe_Util_CreateITensor(input_dims);
    if (!input_tensor) {
        fprintf(stderr, "ERROR: Failed to create input tensor\n");
        exit(EXIT_FAILURE);
    }

    // Load raw data from file
    size_t data_count = 0;
    float* data = load_float_data(input_file, &data_count);
    if (!data) {
        fprintf(stderr, "ERROR: Cannot load input: %s\n", input_file);
        exit(EXIT_FAILURE);
    }

    // Copy into tensor
    float* tensor_data = (float*)Snpe_ITensor_GetData(input_tensor);
    size_t tensor_size = Snpe_ITensor_GetSize(input_tensor);
    size_t copy_size = (data_count < tensor_size) ? data_count : tensor_size;
    memcpy(tensor_data, data, copy_size * sizeof(float));
    free(data);

    printf("  Loaded input: %s (%zu elements)\n", input_file, copy_size);

    // Create TensorMap and add input
    // Note: TensorMap takes ownership of input_tensor handle after Add.
    // Do NOT call Snpe_ITensor_Delete(input_tensor) — it will be deleted
    // when the TensorMap is deleted (returned-by-value ownership transfer).
    Snpe_TensorMap_Handle_t tensor_map = Snpe_TensorMap_Create();
    Snpe_TensorMap_Add(tensor_map, tensor_name, input_tensor);

    // Cleanup handles returned by value (not the tensor — owned by map)
    Snpe_StringList_Delete(input_names);     // Returned by value from GetInputTensorNames
    Snpe_TensorShape_Delete(input_dims);     // Returned by value from GetInputDimensions

    return tensor_map;
}

// ═══════════════════════════════════════════════════════════════════
// Step 5: Execute Network & Save Output (ITensor mode)
// ═══════════════════════════════════════════════════════════════════

static void execute_and_save(
    Snpe_SNPE_Handle_t snpe,
    Snpe_TensorMap_Handle_t input_map,
    const char* output_dir,
    int iteration) {

    // Execute
    Snpe_TensorMap_Handle_t output_map = Snpe_TensorMap_Create();
    Snpe_ErrorCode_t err = Snpe_SNPE_ExecuteITensors(snpe, input_map, output_map);
    if (err != SNPE_SUCCESS) {
        fprintf(stderr, "ERROR: Inference failed (code: %d)\n", err);
        Snpe_TensorMap_Delete(output_map);
        return;
    }

    // Get output tensor names
    Snpe_StringList_Handle_t output_names = Snpe_TensorMap_GetTensorNames(output_map);
    size_t num_outputs = Snpe_StringList_Size(output_names);

    // Save each output tensor
    for (size_t i = 0; i < num_outputs; i++) {
        const char* name = Snpe_StringList_At(output_names, i);
        Snpe_ITensor_Handle_t tensor = Snpe_TensorMap_GetTensor_Ref(output_map, name);

        float* tensor_data = (float*)Snpe_ITensor_GetData(tensor);
        size_t tensor_size = Snpe_ITensor_GetSize(tensor);

        // Build output path: output_dir/Result_N/tensor_name.raw
        char path[1024];
        snprintf(path, sizeof(path), "%s/Result_%d/%s.raw", output_dir, iteration, name);

        save_float_data(path, tensor_data, tensor_size);
    }

    // Cleanup
    // output_names: returned by value from GetTensorNames — must delete
    // output_map: created by us — must delete (also deletes contained tensors)
    // tensor (from GetTensor_Ref): returned by reference — do NOT delete
    //   (auto-deleted when output_map is deleted)
    Snpe_StringList_Delete(output_names);
    Snpe_TensorMap_Delete(output_map);
}

// ─────────────────────────────────────────────────────────────────────────────
// Batched Input: load multiple raw files into a single ITensor, then
// split the batched output back into per-item result files.
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Load multiple input files into a single batched ITensor.
 *
 * Concatenates file_paths[0..batch_size-1] into one contiguous tensor.
 * The network must be built with batch dimension = batch_size
 * (original model or via network resizing / setInputDimensions).
 *
 * Handle ownership:
 *   Returns TensorMap — caller must Snpe_TensorMap_Delete() it.
 *   input_tensor inside is owned by the TensorMap.
 */
static Snpe_TensorMap_Handle_t load_input_tensor_batched(
    Snpe_SNPE_Handle_t snpe,
    const char** file_paths,
    size_t batch_size) {

    // Get single input tensor name
    Snpe_StringList_Handle_t input_names = Snpe_SNPE_GetInputTensorNames(snpe);
    if (!input_names || Snpe_StringList_Size(input_names) < 1) {
        fprintf(stderr, "ERROR: Failed to get input tensor names\n");
        return NULL;
    }
    const char* tensor_name = Snpe_StringList_At(input_names, 0);

    // Get input shape for the batch
    Snpe_TensorShape_Handle_t input_dims = Snpe_SNPE_GetInputDimensions(snpe, tensor_name);
    Snpe_ITensor_Handle_t input_tensor = Snpe_Util_CreateITensor(input_dims);
    if (!input_tensor) {
        fprintf(stderr, "ERROR: Failed to create batched input tensor\n");
        Snpe_StringList_Delete(input_names);
        Snpe_TensorShape_Delete(input_dims);
        return NULL;
    }

    // Load and concatenate batch files into tensor
    float* tensor_data = (float*)Snpe_ITensor_GetData(input_tensor);
    size_t tensor_total = Snpe_ITensor_GetSize(input_tensor);
    size_t per_item = tensor_total / batch_size;  // floats per batch item
    size_t loaded = 0;

    for (size_t i = 0; i < batch_size && loaded < tensor_total; i++) {
        printf("  Batch [%zu]: %s\n", i, file_paths[i]);
        FILE* f = fopen(file_paths[i], "rb");
        if (!f) {
            fprintf(stderr, "ERROR: Cannot open: %s\n", file_paths[i]);
            continue;
        }
        size_t n = fread(tensor_data + loaded, sizeof(float), per_item, f);
        loaded += n;
        fclose(f);
    }

    // Build input TensorMap
    Snpe_TensorMap_Handle_t tensor_map = Snpe_TensorMap_Create();
    Snpe_TensorMap_Add(tensor_map, tensor_name, input_tensor);
    // Note: TensorMap takes ownership of input_tensor — do NOT delete separately

    // Cleanup intermediate handles (returned by value — must delete)
    Snpe_StringList_Delete(input_names);
    Snpe_TensorShape_Delete(input_dims);

    return tensor_map;
}

/**
 * Execute batched ITensor and split output into per-item files.
 *
 * Output tensor is split by dividing total size by batch_size.
 * Files written as: output_dir/Result_{base_num + i}/{name}.raw
 *
 * @param snpe        SNPE instance
 * @param input_map   Batched input TensorMap
 * @param output_dir  Base output directory
 * @param base_num    Starting result index (batch_idx * batch_size)
 * @param batch_size  Number of items in the batch
 */
static void execute_and_save_batched(
    Snpe_SNPE_Handle_t snpe,
    Snpe_TensorMap_Handle_t input_map,
    const char* output_dir,
    int base_num,
    size_t batch_size) {

    // Execute
    Snpe_TensorMap_Handle_t output_map = Snpe_TensorMap_Create();
    Snpe_ErrorCode_t err = Snpe_SNPE_ExecuteITensors(snpe, input_map, output_map);
    if (err != SNPE_SUCCESS) {
        fprintf(stderr, "ERROR: Batched inference failed (code: %d)\n", err);
        Snpe_TensorMap_Delete(output_map);
        return;
    }

    // Get output names (returned by value — must delete)
    Snpe_StringList_Handle_t output_names = Snpe_TensorMap_GetTensorNames(output_map);

    for (size_t t = 0; t < Snpe_StringList_Size(output_names); t++) {
        const char* name = Snpe_StringList_At(output_names, t);
        // GetTensor_Ref → returned by reference — do NOT delete
        Snpe_ITensor_Handle_t tensor = Snpe_TensorMap_GetTensor_Ref(output_map, name);

        float* all_data = (float*)Snpe_ITensor_GetData(tensor);
        size_t total_size = Snpe_ITensor_GetSize(tensor);
        size_t batch_chunk = total_size / batch_size;  // floats per item

        // Write one result file per batch item
        for (size_t i = 0; i < batch_size; i++) {
            char path[1024];
            snprintf(path, sizeof(path), "%s/Result_%d/%s.raw",
                     output_dir, base_num + (int)i, name);
            save_float_data(path, all_data + i * batch_chunk, batch_chunk);
        }
    }

    // Cleanup returned-by-value handles
    Snpe_StringList_Delete(output_names);
    Snpe_TensorMap_Delete(output_map);
}

// ═══════════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════════

int main(int argc, char* argv[]) {
    const char* model_path = "{{ model_path }}";
    const char* input_list_file = "{{ input_list | default('input_list.txt') }}";
    const char* output_dir = "{{ output_dir | default('./output') }}";

    // Override from command line
    if (argc > 1) model_path = argv[1];
    if (argc > 2) input_list_file = argv[2];
    if (argc > 3) output_dir = argv[3];

    // ── SNPE Logging ──────────────────────────────────────────────────────────
    // Initialize ONCE at program start to capture logs from all processes.
    // Performance note: logging adds overhead — use WARN or ERROR in production.
    // Android: logs → logcat.  Non-Android: logs → console + log files at path.
{% if log_level | default('') %}
{% if is_android | default(false) %}
    Snpe_Util_InitializeLogging(SNPE_LOG_LEVEL_{{ log_level | upper }});
{% else %}
    Snpe_Util_InitializeLoggingPath(SNPE_LOG_LEVEL_{{ log_level | upper }},
                                    "{{ log_path | default('./snpe_logs') }}");
{% endif %}
{% else %}
    // SNPE logging disabled (pass log_level variable to enable)
    // Example: Snpe_Util_InitializeLogging(SNPE_LOG_LEVEL_WARN);
{% endif %}

    printf("═══════════════════════════════════════════════════════\n");
    printf("  QUAD — SNPE Inference (C API)\n");
    printf("  Model: %s\n", model_path);
    printf("═══════════════════════════════════════════════════════\n\n");

    // Step 1: Check runtime
    Snpe_Runtime_t runtime = check_runtime();

    // Step 2: Load container
    Snpe_DlContainer_Handle_t container = load_container(model_path);

    // Step 3: Build SNPE (ITensor mode)
    Snpe_SNPE_Handle_t snpe = build_snpe(container, runtime, false);

{% if enable_init_cache | default(false) %}
    // ── Init Cache: save container after build ────────────────────────────────
    // Persists initialization structures to the DLC so future loads skip
    // re-computation. Supported on DSP and AIP runtimes only.
    //
    // Rules (SNPE Init Caching docs):
    //   - Call Snpe_DlContainer_Save() after EVERY build (no-op if unchanged).
    //   - SDK auto-invalidates stale caches on library version mismatch.
    //   - Same open→build→save sequence handles both first-run and reuse.
    if (Snpe_DlContainer_Save(container, model_path) != SNPE_SUCCESS) {
        fprintf(stderr, "WARNING: Failed to save init cache to: %s\n", model_path);
    } else {
        printf("Init cache saved: %s\n", model_path);
    }
{% endif %}

    // Step 4-5: Process each input from list
    FILE* list_file = fopen(input_list_file, "r");
    if (!list_file) {
        fprintf(stderr, "ERROR: Cannot open input list: %s\n", input_list_file);
        return EXIT_FAILURE;
    }

    char line[1024];
    int iteration = 0;
    while (fgets(line, sizeof(line), list_file)) {
        // Strip newline
        line[strcspn(line, "\r\n")] = '\0';
        if (line[0] == '\0' || line[0] == '#') continue;

        printf("\nProcessing [%d]: %s\n", iteration, line);

        Snpe_TensorMap_Handle_t input_map = load_input_tensor(snpe, line);
        execute_and_save(snpe, input_map, output_dir, iteration);

        // Cleanup input tensor map
        Snpe_TensorMap_Delete(input_map);
        iteration++;
    }
    fclose(list_file);

    // Cleanup
    Snpe_SNPE_Delete(snpe);
    Snpe_DlContainer_Delete(container);
{% if log_level | default("") %}
    Snpe_Util_TerminateLogging();
{% endif %}

    printf("\n═══════════════════════════════════════════════════════\n");
    printf("  Done! Processed %d inputs.\n", iteration);
    printf("  Results: %s/\n", output_dir);
    printf("═══════════════════════════════════════════════════════\n");

    return EXIT_SUCCESS;
}
