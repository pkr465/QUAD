// ═══════════════════════════════════════════════════════════════════
// Utility: Load raw float data from file
// ═══════════════════════════════════════════════════════════════════

static float* load_float_data(const char* path, size_t* out_count) {
    FILE* f = fopen(path, "rb");
    if (!f) {
        fprintf(stderr, "ERROR: Cannot open input file: %s\n", path);
        return NULL;
    }
    fseek(f, 0, SEEK_END);
    long size = ftell(f);
    fseek(f, 0, SEEK_SET);

    *out_count = size / sizeof(float);
    float* data = (float*)malloc(size);
    if (!data) {
        fclose(f);
        return NULL;
    }
    fread(data, sizeof(float), *out_count, f);
    fclose(f);
    return data;
}

static void save_float_data(const char* path, const float* data, size_t count) {
    // Create parent directory
    char dir[512];
    strncpy(dir, path, sizeof(dir) - 1);
    char* last_slash = strrchr(dir, '/');
    if (last_slash) {
        *last_slash = '\0';
        char cmd[1024];
        snprintf(cmd, sizeof(cmd), "mkdir -p %s", dir);
        system(cmd);
    }

    FILE* f = fopen(path, "wb");
    if (!f) {
        fprintf(stderr, "ERROR: Cannot write output: %s\n", path);
        return;
    }
    fwrite(data, sizeof(float), count, f);
    fclose(f);
    printf("  Output saved: %s (%zu floats)\n", path, count);
}

