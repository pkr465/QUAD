cmake_minimum_required(VERSION 3.14)
project(quad_snpe_c_inference C)

set(CMAKE_C_STANDARD 11)
set(CMAKE_C_STANDARD_REQUIRED ON)

# ── SNPE SDK ──
{% if sdk_path %}
set(SNPE_ROOT "{{ sdk_path }}")
{% else %}
if(DEFINED ENV{SNPE_ROOT})
    set(SNPE_ROOT $ENV{SNPE_ROOT})
elseif(DEFINED ENV{QAIRT_SDK_ROOT})
    set(SNPE_ROOT $ENV{QAIRT_SDK_ROOT})
else()
    message(FATAL_ERROR "SNPE_ROOT or QAIRT_SDK_ROOT not set.")
endif()
{% endif %}

message(STATUS "SNPE_ROOT: ${SNPE_ROOT}")

# ── Platform Detection ──
if(WIN32)
    if(CMAKE_GENERATOR_PLATFORM STREQUAL "ARM64" OR CMAKE_SYSTEM_PROCESSOR STREQUAL "ARM64")
        set(TARGET_ARCH "aarch64-windows-msvc")
    else()
        set(TARGET_ARCH "x86_64-windows-msvc")
    endif()
    set(SNPE_LIB_NAME "SNPE")
else()
{% if target_arch %}
    set(TARGET_ARCH "{{ target_arch }}")
{% else %}
    set(TARGET_ARCH "x86_64-linux-clang")
{% endif %}
    set(SNPE_LIB_NAME "SNPE")
endif()

message(STATUS "TARGET_ARCH: ${TARGET_ARCH}")

# ── Optional: Static VCRUNTIME (Windows — avoids needing redistributable) ──
option(BUILD_WITH_VCRUNTIME "Build with static MSVC runtime (/MT)" OFF)
if(WIN32 AND BUILD_WITH_VCRUNTIME)
    set(CMAKE_MSVC_RUNTIME_LIBRARY "MultiThreaded$<$<CONFIG:Debug>:Debug>")
endif()

# ── Include / Link ──
include_directories(${SNPE_ROOT}/include/SNPE)
link_directories(${SNPE_ROOT}/lib/${TARGET_ARCH})

# ── Source ──
add_executable(inference inference.c)
target_link_libraries(inference ${SNPE_LIB_NAME})
if(NOT WIN32)
    target_link_libraries(inference m)
endif()

# ── Post-build: Copy runtime libraries ──
if(WIN32)
    # Copy all SNPE DLLs (SNPE.dll + HTP/DSP stubs)
    file(GLOB SNPE_DLLS "${SNPE_ROOT}/lib/${TARGET_ARCH}/*.dll")
    foreach(DLL ${SNPE_DLLS})
        add_custom_command(TARGET inference POST_BUILD
            COMMAND ${CMAKE_COMMAND} -E copy_if_different "${DLL}" $<TARGET_FILE_DIR:inference>)
    endforeach()
else()
    add_custom_command(TARGET inference POST_BUILD
        COMMAND ${CMAKE_COMMAND} -E copy_if_different
            "${SNPE_ROOT}/lib/${TARGET_ARCH}/libSNPE.so" $<TARGET_FILE_DIR:inference>)
endif()

# ═══════════════════════════════════════════════════════════════════
# Build Instructions:
#
# Linux (x86_64):   cmake .. && cmake --build . --config Release
# Windows (x64):    cmake .. -A x64 && cmake --build . --config Release
# Windows (ARM64):  cmake .. -A ARM64 && cmake --build . --config Release
# Windows (static): cmake .. -A ARM64 -DBUILD_WITH_VCRUNTIME=ON
# ═══════════════════════════════════════════════════════════════════
