// ═══════════════════════════════════════════════════════════════════
// Application-owned buffers
// ═══════════════════════════════════════════════════════════════════

#define MAX_BUFFERS 16

typedef struct {
    char name[256];
    uint8_t* data;
    size_t size;
    Snpe_IUserBuffer_Handle_t handle;
} AppBuffer;

typedef struct {
    AppBuffer buffers[MAX_BUFFERS];
    int count;
} AppBufferStore;

static AppBufferStore g_input_buffers = {0};
static AppBufferStore g_output_buffers = {0};

// ═══════════════════════════════════════════════════════════════════
// Step 1-3: Runtime + Load + Build (same as ITensor mode)
// ═══════════════════════════════════════════════════════════════════

static Snpe_Runtime_t check_runtime(void) {
    Snpe_DlVersion_Handle_t version = Snpe_Util_GetLibraryVersion();
    printf("SNPE Version: %s\n", Snpe_DlVersion_ToString(version));
    Snpe_DlVersion_Delete(version);

{% if runtime == 'dsp' or runtime == 'npu' %}
    if (Snpe_Util_IsRuntimeAvailable(SNPE_RUNTIME_DSP)) return SNPE_RUNTIME_DSP;
{% elif runtime == 'gpu' %}
    if (Snpe_Util_IsRuntimeAvailable(SNPE_RUNTIME_GPU)) return SNPE_RUNTIME_GPU;
{% endif %}
    return SNPE_RUNTIME_CPU;
}

static Snpe_DlContainer_Handle_t load_container(const char* path) {
    Snpe_DlContainer_Handle_t h = Snpe_DlContainer_Open(path);
    if (!h) { fprintf(stderr, "ERROR: Cannot open DLC: %s\n", path); exit(1); }
    return h;
}

static Snpe_SNPE_Handle_t build_snpe(Snpe_DlContainer_Handle_t container, Snpe_Runtime_t runtime) {
    Snpe_RuntimeList_Handle_t rl = Snpe_RuntimeList_Create();
    Snpe_RuntimeList_Add(rl, runtime);
    Snpe_SNPEBuilder_Handle_t b = Snpe_SNPEBuilder_Create(container);
    Snpe_SNPEBuilder_SetRuntimeProcessorOrder(b, rl);
    Snpe_SNPEBuilder_SetUseUserSuppliedBuffers(b, true);  // UserBuffer mode
    Snpe_SNPE_Handle_t snpe = Snpe_SNPEBuilder_Build(b);
    Snpe_SNPEBuilder_Delete(b);
    Snpe_RuntimeList_Delete(rl);
    if (!snpe) { fprintf(stderr, "ERROR: Build failed\n"); exit(1); }
    return snpe;
}

// ═══════════════════════════════════════════════════════════════════
// Step 4: Create UserBuffers (Zero-Copy)
// ═══════════════════════════════════════════════════════════════════

/**
 * Create a UserBuffer for a named input/output tensor.
 * The buffer memory is owned by the application — SNPE reads/writes directly.
 */
static void create_user_buffer(
    Snpe_UserBufferMap_Handle_t map,
    AppBufferStore* store,
    Snpe_SNPE_Handle_t snpe,
    const char* name) {

    // Get buffer attributes
    Snpe_IBufferAttributes_Handle_t attrs = Snpe_SNPE_GetInputOutputBufferAttributes(snpe, name);
    if (!attrs) { fprintf(stderr, "ERROR: No attributes for: %s\n", name); return; }

    Snpe_TensorShape_Handle_t shape = Snpe_IBufferAttributes_GetDims(attrs);
    size_t rank = Snpe_TensorShape_Rank(shape);

    // Calculate strides (tightly packed)
    size_t strides[8] = {0};
    strides[rank - 1] = sizeof(float);
    for (int i = (int)rank - 2; i >= 0; i--) {
        strides[i] = strides[i + 1] * Snpe_TensorShape_At(shape, i + 1);
    }
    Snpe_TensorShape_Handle_t strides_handle = Snpe_TensorShape_CreateDimsSize(strides, rank);

    // Calculate total buffer size
    size_t elem_size = Snpe_IBufferAttributes_GetElementSize(attrs);
    size_t buf_size = elem_size;
    for (size_t i = 0; i < rank; i++) {
        buf_size *= Snpe_TensorShape_At(shape, i);
    }

    // Allocate application buffer
    int idx = store->count;
    strncpy(store->buffers[idx].name, name, sizeof(store->buffers[idx].name) - 1);
    store->buffers[idx].data = (uint8_t*)calloc(1, buf_size);
    store->buffers[idx].size = buf_size;

    // Create SNPE UserBuffer wrapping our memory
    Snpe_UserBufferEncoding_Handle_t encoding = Snpe_UserBufferEncodingFloat_Create();
    store->buffers[idx].handle = Snpe_Util_CreateUserBuffer(
        store->buffers[idx].data, buf_size, strides_handle, encoding);

    // Add to map
    Snpe_UserBufferMap_Add(map, name, store->buffers[idx].handle);
    store->count++;

    // Cleanup intermediate handles
    Snpe_IBufferAttributes_Delete(attrs);
    Snpe_TensorShape_Delete(shape);
    Snpe_TensorShape_Delete(strides_handle);
    Snpe_UserBufferEncodingFloat_Delete(encoding);

    printf("  Created UserBuffer: %s (%zu bytes)\n", name, buf_size);
}

// ═══════════════════════════════════════════════════════════════════
// Step 5: Load Input Data into UserBuffer
// ═══════════════════════════════════════════════════════════════════

static void load_input_data(AppBufferStore* store, const char* filepath, int input_idx) {
    if (input_idx >= store->count) return;

    FILE* f = fopen(filepath, "rb");
    if (!f) { fprintf(stderr, "ERROR: Cannot open: %s\n", filepath); return; }
    fread(store->buffers[input_idx].data, 1, store->buffers[input_idx].size, f);
    fclose(f);
}

// ═══════════════════════════════════════════════════════════════════
// Step 6: Execute & Save Output
// ═══════════════════════════════════════════════════════════════════

static void execute_and_save(
    Snpe_SNPE_Handle_t snpe,
    Snpe_UserBufferMap_Handle_t input_map,
    Snpe_UserBufferMap_Handle_t output_map,
    AppBufferStore* out_store,
    const char* output_dir,
    int iteration) {

    // Execute (zero-copy — SNPE reads/writes directly to our buffers)
    Snpe_SNPE_ExecuteUserBuffers(snpe, input_map, output_map);

    // Save output buffers
    for (int i = 0; i < out_store->count; i++) {
        char path[1024];
        snprintf(path, sizeof(path), "%s/Result_%d/%s.raw",
                 output_dir, iteration, out_store->buffers[i].name);

        // mkdir -p
        char dir[1024];
        snprintf(dir, sizeof(dir), "%s/Result_%d", output_dir, iteration);
        char cmd[1100];
        snprintf(cmd, sizeof(cmd), "mkdir -p %s", dir);
        system(cmd);

        FILE* f = fopen(path, "wb");
        if (f) {
            fwrite(out_store->buffers[i].data, 1, out_store->buffers[i].size, f);
            fclose(f);
            printf("  Output: %s\n", path);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════
// Cleanup
// ═══════════════════════════════════════════════════════════════════

static void cleanup_buffers(AppBufferStore* store) {
    for (int i = 0; i < store->count; i++) {
        Snpe_IUserBuffer_Delete(store->buffers[i].handle);
        free(store->buffers[i].data);
    }
    store->count = 0;
}

// ═══════════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════════

int main(int argc, char* argv[]) {
    const char* model_path = "{{ model_path }}";
    const char* input_list_file = "{{ input_list | default('input_list.txt') }}";
    const char* output_dir = "{{ output_dir | default('./output') }}";

    if (argc > 1) model_path = argv[1];
    if (argc > 2) input_list_file = argv[2];
    if (argc > 3) output_dir = argv[3];

    printf("═══════════════════════════════════════════════════════\n");
    printf("  QUAD — SNPE Inference (C API — UserBuffer Mode)\n");
    printf("  Model: %s\n", model_path);
    printf("═══════════════════════════════════════════════════════\n\n");

    // Build
    Snpe_Runtime_t runtime = check_runtime();
    Snpe_DlContainer_Handle_t container = load_container(model_path);
    Snpe_SNPE_Handle_t snpe = build_snpe(container, runtime);

    // Create UserBuffer maps
    Snpe_UserBufferMap_Handle_t input_map = Snpe_UserBufferMap_Create();
    Snpe_UserBufferMap_Handle_t output_map = Snpe_UserBufferMap_Create();

    // Create input UserBuffers (one per network input)
    printf("Creating input buffers:\n");
    Snpe_StringList_Handle_t input_names = Snpe_SNPE_GetInputTensorNames(snpe);
    for (size_t i = 0; i < Snpe_StringList_Size(input_names); i++) {
        create_user_buffer(input_map, &g_input_buffers, snpe, Snpe_StringList_At(input_names, i));
    }
    Snpe_StringList_Delete(input_names);

    // Create output UserBuffers
    printf("Creating output buffers:\n");
    Snpe_StringList_Handle_t output_names = Snpe_SNPE_GetOutputTensorNames(snpe);
    for (size_t i = 0; i < Snpe_StringList_Size(output_names); i++) {
        create_user_buffer(output_map, &g_output_buffers, snpe, Snpe_StringList_At(output_names, i));
    }
    Snpe_StringList_Delete(output_names);

    // Process input list
    FILE* list = fopen(input_list_file, "r");
    if (!list) { fprintf(stderr, "ERROR: Cannot open: %s\n", input_list_file); return 1; }

    char line[1024];
    int iteration = 0;
    while (fgets(line, sizeof(line), list)) {
        line[strcspn(line, "\r\n")] = '\0';
        if (line[0] == '\0' || line[0] == '#') continue;

        printf("\n[%d] %s\n", iteration, line);
        load_input_data(&g_input_buffers, line, 0);
        execute_and_save(snpe, input_map, output_map, &g_output_buffers, output_dir, iteration);
        iteration++;
    }
    fclose(list);

    // Cleanup
    cleanup_buffers(&g_input_buffers);
    cleanup_buffers(&g_output_buffers);
    Snpe_UserBufferMap_Delete(input_map);
    Snpe_UserBufferMap_Delete(output_map);
    Snpe_SNPE_Delete(snpe);
    Snpe_DlContainer_Delete(container);

    printf("\n═══════════════════════════════════════════════════════\n");
    printf("  Done! Processed %d inputs.\n  Results: %s/\n", iteration, output_dir);
    printf("═══════════════════════════════════════════════════════\n");
    return 0;
}
