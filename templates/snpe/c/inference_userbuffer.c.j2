/**
 * SNPE C API — UserBuffer Mode (Zero-Copy)
 *
 * Auto-generated by QUAD (Qualcomm Unified Agent for Developers).
 * Based on: $SNPE_ROOT/examples/SNPE/NativeCpp/SampleCode_CAPI/
 *
 * UserBuffer mode eliminates the copy from user memory to SNPE tensors.
 * SNPE reads/writes directly from your buffers — higher performance.
 *
 * Handle Lifecycle Rules:
 * 1. _Create() → user must _Delete()
 * 2. Returned by value (no _Ref) → user must _Delete()
 * 3. Returned by reference (_Ref) → auto-deleted with parent
 *
 * Model: {{ model_path }}
 * Runtime: {{ runtime | default('cpu') }}
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <assert.h>
#include <stdbool.h>

#include "SNPE/SNPE.h"
#include "SNPE/SNPEBuilder.h"
#include "SNPE/SNPEFactory.h"
