    platformConfig.setPlatformOptions("{{ platform_options }}");
{% else %}
    platformConfig.setPlatformOptions("unsignedPD:ON");
{% endif %}
{% endif %}

    auto snpe = builder
        .setRuntimeProcessorOrder({runtime})
        .setUseUserSuppliedBuffers(useUserSuppliedBuffers)
{% if enable_init_cache | default(false) %}
        .setInitCacheMode(true)
{% endif %}
{% if performance_profile | default('') %}
        .setPerformanceProfile(zdl::DlSystem::PerformanceProfile_t::{{ performance_profile | upper }})
{% endif %}
{% if pd_type | default('unsigned') == 'signed' or platform_options | default('') %}
        .setPlatformConfig(platformConfig)
{% endif %}
{% if enable_cpu_fxp | default(false) %}
        // ── CPU Fixed Point Mode ───────────────────────────────────────────────
        // Executes quantized DLC on CPU without dequantization step.
        // Requirements: quantized DLC + CPU runtime selected.
        // Not all ops support FXP; unsupported ops fall back to CPU float.
        // DSP→CPU fallback also uses FXP (no dequant = better perf).
        .setCpuFixedPointMode(true)
{% endif %}
        .build();

{% if cache_compatibility_mode | default('') %}
    // ── HNRD Cache Compatibility Mode ─────────────────────────────────────────
    // On Windows with HNRD, caches may be sub-optimal after driver upgrades.
    // STRICT: fail on sub-optimal. PERMISSIVE: allow. ALWAYS_GENERATE: force regen.
    // See: Hexagon NPU Runtime Driver (HNRD) documentation.
    {
        zdl::DlSystem::CacheCompatibilityMode mode =
            zdl::DlSystem::CacheCompatibilityMode_t::{{ cache_compatibility_mode }};
        builder.setCacheCompatibilityMode(mode);
    }
{% endif %}

    if (!snpe) {
        std::cerr << "ERROR: Failed to build SNPE" << std::endl;
        std::exit(EXIT_FAILURE);
    }

{% if enable_init_cache | default(false) %}
    // ── Init Cache: persist to DLC after first build ─────────────────────────
    // Init caching stores initialization structures in the DLC container so
    // that subsequent loads skip re-computation, significantly reducing
    // initialization time. Supported runtimes: DSP and AIP only.
    //
    // Rules (from SNPE Init Caching docs):
    //   1. Call container->save() AFTER every build when using init caching.
    //   2. If cache is unchanged, save() is a no-op — safe to always call.
    //   3. SDK auto-invalidates stale caches (library version mismatch, etc.).
    //   4. The same code sequence (open → build → save) works for both
    //      first-time generation AND subsequent reuse.
    container->save("{{ model_path }}");
    std::cout << "Init cache saved to: {{ model_path }}" << std::endl;
{% endif %}

    return snpe;
}

