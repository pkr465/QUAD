/**
 * Create a UserBuffer from application-owned memory.
 * Zero-copy: SNPE reads/writes directly to your buffer.
 */
void createUserBuffer(
    zdl::DlSystem::UserBufferMap& userBufferMap,
    std::unordered_map<std::string, std::vector<uint8_t>>& applicationBuffers,
    std::vector<std::unique_ptr<zdl::DlSystem::IUserBuffer>>& snpeUserBackedBuffers,
    std::unique_ptr<zdl::SNPE::SNPE>& snpe,
    const char* name) {

    // Get buffer attributes
    auto bufferAttributesOpt = snpe->getInputOutputBufferAttributes(name);
    if (!bufferAttributesOpt) {
        std::cerr << "ERROR: Cannot get attributes for: " << name << std::endl;
        return;
    }

    const zdl::DlSystem::TensorShape& bufferShape = (*bufferAttributesOpt)->getDims();

    // Calculate strides (tightly packed)
    std::vector<size_t> strides(bufferShape.rank());
    strides[strides.size() - 1] = sizeof(float);
    size_t stride = strides[strides.size() - 1];
    for (size_t i = bufferShape.rank() - 1; i > 0; i--) {
        stride *= bufferShape[i];
        strides[i - 1] = stride;
    }

    // Calculate buffer size
    const size_t elementSize = (*bufferAttributesOpt)->getElementSize();
    size_t bufSize = calcSizeFromDims(
        bufferShape.getDimensions(), bufferShape.rank(), elementSize);

    // Create application-owned buffer
    applicationBuffers.emplace(name, std::vector<uint8_t>(bufSize));

    // Create SNPE UserBuffer wrapping our memory
    zdl::DlSystem::UserBufferEncodingFloat encoding;
    auto& factory = zdl::SNPE::SNPEFactory::getUserBufferFactory();
    snpeUserBackedBuffers.push_back(
        factory.createUserBuffer(
            applicationBuffers.at(name).data(), bufSize, strides, &encoding));

    // Add to map
    userBufferMap.add(name, snpeUserBackedBuffers.back().get());
}

/**
 * Load input data into UserBuffer (multi-input support).
 */
void loadInputUserBuffer(
    std::unordered_map<std::string, std::vector<uint8_t>>& applicationBuffers,
    std::unique_ptr<zdl::SNPE::SNPE>& snpe,
    const std::string& fileLine) {

    const auto& inputNamesOpt = snpe->getInputTensorNames();
    if (!inputNamesOpt) {
        std::cerr << "ERROR: Cannot get input tensor names" << std::endl;
        return;
    }
    const auto& inputNames = *inputNamesOpt;

    // Parse space-separated input file paths (one per network input)
    std::vector<std::string> filePaths;
    split(filePaths, fileLine, ' ');

    std::cout << "Loading inputs (UserBuffer mode):" << std::endl;
    for (size_t i = 0; i < inputNames.size() && i < filePaths.size(); i++) {
        const char* name = inputNames.at(i);
        std::cout << "  " << (i + 1) << ") " << filePaths[i] << std::endl;
        loadByteDataFile(filePaths[i], applicationBuffers.at(name));
    }
}

/**
 * Execute with UserBuffers and save output.
 */
void executeUserBuffer(
    std::unique_ptr<zdl::SNPE::SNPE>& snpe,
    zdl::DlSystem::UserBufferMap& inputMap,
    zdl::DlSystem::UserBufferMap& outputMap,
    std::unordered_map<std::string, std::vector<uint8_t>>& outputBuffers,
    const std::string& outputDir,
    int num) {

    // Execute (zero-copy — SNPE reads/writes directly to user buffers)
    snpe->execute(inputMap, outputMap);

    // Save outputs
    const auto& outputNames = outputMap.getUserBufferNames();
    std::for_each(outputNames.begin(), outputNames.end(), [&](const char* name) {
        std::ostringstream path;
        path << outputDir << "/Result_" << num << "/" << name << ".raw";
        saveOutput(path.str(), outputBuffers.at(name));
    });
}
