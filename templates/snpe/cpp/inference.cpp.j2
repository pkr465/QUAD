static void split(std::vector<std::string>& out, const std::string& str, char delim) {
    std::istringstream ss(str);
    std::string item;
    while (std::getline(ss, item, delim)) {
        if (!item.empty()) out.push_back(item);
    }
}

static std::vector<float> loadFloatDataFile(const std::string& path) {
    std::ifstream file(path, std::ios::binary);
    if (!file) {
        std::cerr << "ERROR: Cannot open: " << path << std::endl;
        return {};
    }
    file.seekg(0, std::ios::end);
    size_t size = file.tellg() / sizeof(float);
    file.seekg(0, std::ios::beg);
    std::vector<float> data(size);
    file.read(reinterpret_cast<char*>(data.data()), size * sizeof(float));
    return data;
}

static void loadByteDataFile(const std::string& path, std::vector<uint8_t>& buffer) {
    std::ifstream file(path, std::ios::binary);
    if (!file) {
        std::cerr << "ERROR: Cannot open: " << path << std::endl;
        return;
    }
    file.read(reinterpret_cast<char*>(buffer.data()), buffer.size());
}

static size_t calcSizeFromDims(const size_t* dims, size_t rank, size_t elementSize) {
    size_t size = elementSize;
    for (size_t i = 0; i < rank; i++) size *= dims[i];
    return size;
}

static void saveOutput(const std::string& path, const float* data, size_t count) {
    std::string dir = path.substr(0, path.rfind('/'));
    system(("mkdir -p " + dir).c_str());
    std::ofstream os(path, std::ofstream::binary);
    if (!os) { std::cerr << "ERROR: Cannot write: " << path << std::endl; return; }
    os.write(reinterpret_cast<const char*>(data), count * sizeof(float));
}

static void saveOutput(const std::string& path, const std::vector<uint8_t>& buffer) {
    std::string dir = path.substr(0, path.rfind('/'));
    system(("mkdir -p " + dir).c_str());
    std::ofstream os(path, std::ofstream::binary);
    if (!os) { std::cerr << "ERROR: Cannot write: " << path << std::endl; return; }
    os.write(reinterpret_cast<const char*>(buffer.data()), buffer.size());
}

