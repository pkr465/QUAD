zdl::DlSystem::Runtime_t checkRuntime() {
    auto version = zdl::SNPE::SNPEFactory::getLibraryVersion();
    std::cout << "SNPE Version: " << version.asString().c_str() << std::endl;

{% if runtime == 'dsp' or runtime == 'npu' %}
    if (zdl::SNPE::SNPEFactory::isRuntimeAvailable(zdl::DlSystem::Runtime_t::DSP)) {
        std::cout << "Runtime: DSP (Hexagon)" << std::endl;
        return zdl::DlSystem::Runtime_t::DSP;
    }
{% elif runtime == 'gpu' %}
    if (zdl::SNPE::SNPEFactory::isRuntimeAvailable(zdl::DlSystem::Runtime_t::GPU)) {
        std::cout << "Runtime: GPU (Adreno)" << std::endl;
        return zdl::DlSystem::Runtime_t::GPU;
    }
{% elif runtime == 'aip' %}
    if (zdl::SNPE::SNPEFactory::isRuntimeAvailable(zdl::DlSystem::Runtime_t::AIP_FIXED8_TF)) {
        std::cout << "Runtime: AIP (HTA+HVX)" << std::endl;
        return zdl::DlSystem::Runtime_t::AIP_FIXED8_TF;
    }
{% endif %}
    std::cout << "Runtime: CPU (fallback)" << std::endl;
    return zdl::DlSystem::Runtime_t::CPU;
}

