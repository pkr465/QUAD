int main(int argc, char* argv[]) {
    // Defaults (override via command line)
    std::string modelPath = "{{ model_path }}";
    std::string inputListFile = "{{ input_list | default('input_list.txt') }}";
    std::string outputDir = "{{ output_dir | default('./output') }}";
{% if buffer_mode | default('USERBUFFER_FLOAT') == 'ITENSOR' %}
    bool useUserBuffers = false;
{% else %}
    bool useUserBuffers = true;
{% endif %}
{% if udo_package_path | default('') %}
    std::string udoPath = "{{ udo_package_path }}";
{% endif %}

    // Parse command line
    for (int i = 1; i < argc; i++) {
        std::string arg(argv[i]);
        if (arg == "-d" && i + 1 < argc) modelPath = argv[++i];
        else if (arg == "-i" && i + 1 < argc) inputListFile = argv[++i];
        else if (arg == "-o" && i + 1 < argc) outputDir = argv[++i];
        else if (arg == "-b" && i + 1 < argc) {
            std::string mode(argv[++i]);
            useUserBuffers = (mode != "ITENSOR");
        }
{% if udo_package_path | default('') %}
        else if (arg == "-u" && i + 1 < argc) udoPath = argv[++i];
{% endif %}
        else if (arg == "-h") {
            std::cout << "Usage: inference -d <model.dlc> -i <input_list.txt> -o <output_dir>\n"
                      << "  -b  Buffer type [USERBUFFER_FLOAT, USERBUFFER_TF8, ITENSOR]\n"
{% if udo_package_path | default('') %}
                      << "  -u  UDO package path(s), comma-separated\n"
{% endif %}
                      << "  -h  Show help\n";
            return 0;
        }
    }

    std::cout << "═══════════════════════════════════════════════════════\n"
              << "  QUAD — SNPE Inference (C++)\n"
              << "  Model:  " << modelPath << "\n"
              << "  Buffer: " << (useUserBuffers ? "UserBuffer (zero-copy)" : "ITensor") << "\n"
              << "═══════════════════════════════════════════════════════\n\n";

    // Step 1: Runtime
    auto runtime = checkRuntime();

    // Step 2: Load container
    auto container = loadContainerFromFile(modelPath);

{% if udo_package_path | default('') %}
    // Step 3: Load UDO (optional)
    if (!udoPath.empty()) loadUDOPackage(udoPath);
{% endif %}

    // Step 4: Build SNPE
    auto snpe = setBuilderOptions(container, runtime, useUserBuffers);

{% if buffer_mode | default('USERBUFFER_FLOAT') != 'ITENSOR' %}
    // Setup UserBuffers
    zdl::DlSystem::UserBufferMap inputMap, outputMap;
    std::unordered_map<std::string, std::vector<uint8_t>> inputBuffers, outputBuffers;
    std::vector<std::unique_ptr<zdl::DlSystem::IUserBuffer>> inputUBs, outputUBs;

    // Create input UserBuffers
    const auto& inputNames = *snpe->getInputTensorNames();
    for (size_t i = 0; i < inputNames.size(); i++) {
        createUserBuffer(inputMap, inputBuffers, inputUBs, snpe, inputNames.at(i));
    }
    // Create output UserBuffers
    const auto& outputNames = *snpe->getOutputTensorNames();
    for (size_t i = 0; i < outputNames.size(); i++) {
        createUserBuffer(outputMap, outputBuffers, outputUBs, snpe, outputNames.at(i));
    }
{% endif %}

    // Process inputs
    std::ifstream inputList(inputListFile);
    if (!inputList) {
        std::cerr << "ERROR: Cannot open: " << inputListFile << std::endl;
        return EXIT_FAILURE;
    }

    std::string line;
    int iteration = 0;
    while (std::getline(inputList, line)) {
        if (line.empty() || line[0] == '#') continue;
        std::cout << "\n[" << iteration << "] " << line << std::endl;

{% if buffer_mode | default('USERBUFFER_FLOAT') != 'ITENSOR' %}
        loadInputUserBuffer(inputBuffers, snpe, line);
        executeUserBuffer(snpe, inputMap, outputMap, outputBuffers, outputDir, iteration);
{% else %}
        auto input = loadInputTensor(snpe, line);
        if (input) executeITensor(snpe, input, outputDir, iteration);
{% endif %}
        iteration++;
    }

    std::cout << "\n═══════════════════════════════════════════════════════\n"
              << "  Done! Processed " << iteration << " inputs.\n"
              << "  Results: " << outputDir << "/\n"
              << "═══════════════════════════════════════════════════════\n";

    return EXIT_SUCCESS;
}
