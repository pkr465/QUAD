std::unique_ptr<zdl::DlContainer::IDlContainer> loadContainerFromFile(const std::string& path) {
    auto container = zdl::DlContainer::IDlContainer::open(path);
    if (!container) {
        std::cerr << "ERROR: Failed to open DLC: " << path << std::endl;
        std::exit(EXIT_FAILURE);
    }
    return container;
}

