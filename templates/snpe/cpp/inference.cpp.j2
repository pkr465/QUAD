/**
 * Load input into ITensor (single or multi-input support).
 */
std::unique_ptr<zdl::DlSystem::ITensor> loadInputTensor(
    std::unique_ptr<zdl::SNPE::SNPE>& snpe,
    const std::string& fileLine) {

    const auto& inputNamesOpt = snpe->getInputTensorNames();
    if (!inputNamesOpt) {
        std::cerr << "ERROR: Cannot get input tensor names" << std::endl;
        return nullptr;
    }
    const auto& inputNames = *inputNamesOpt;
    assert(inputNames.size() >= 1);

    // For single-input: entire line is the file path
    std::string filePath(fileLine);
    std::cout << "Loading input (ITensor): " << filePath << std::endl;

    std::vector<float> inputVec = loadFloatDataFile(filePath);
    if (inputVec.empty()) return nullptr;

    // Create tensor with network's expected input shape
    const auto& inputDimsOpt = snpe->getInputDimensions(inputNames.at(0));
    auto input = zdl::SNPE::SNPEFactory::getTensorFactory().createTensor(*inputDimsOpt);

    // Copy data into tensor
    std::copy(inputVec.begin(), inputVec.end(), input->begin());
    return input;
}

/**
 * Load a BATCH of inputs into a single ITensor.
 *
 * Concatenates batchSize raw input files into one tensor.
 * Requires the network to have been built with batch dimension = batchSize
 * (either by original model or via setInputDimensions/network resizing).
 *
 * @param snpe     SNPE instance
 * @param filePaths  Vector of input file paths (one per batch item)
 * @param batchSize  Number of items to batch together
 */
std::unique_ptr<zdl::DlSystem::ITensor> loadInputTensorBatched(
    std::unique_ptr<zdl::SNPE::SNPE>& snpe,
    const std::vector<std::string>& filePaths,
    size_t batchSize) {

    const auto& inputNamesOpt = snpe->getInputTensorNames();
    if (!inputNamesOpt) throw std::runtime_error("Error obtaining input tensor names");
    const auto& inputNames = *inputNamesOpt;
    assert(inputNames.size() == 1);  // Batched loading: single-input network

    // Concatenate all batch inputs into a single flat vector
    std::vector<float> inputVec;
    for (size_t i = 0; i < batchSize && i < filePaths.size(); i++) {
        std::cout << "Batch [" << i << "]: " << filePaths[i] << std::endl;
        std::vector<float> loaded = loadFloatDataFile(filePaths[i]);
        inputVec.insert(inputVec.end(), loaded.begin(), loaded.end());
    }

    // Create tensor sized for the full batch
    const auto& inputDimsOpt = snpe->getInputDimensions(inputNames.at(0));
    auto input = zdl::SNPE::SNPEFactory::getTensorFactory().createTensor(*inputDimsOpt);

    // Copy concatenated batch data into tensor (STL-compatible)
    std::copy(inputVec.begin(), inputVec.end(), input->begin());
    return input;
}

/**
 * Execute with ITensors and save output (single input).
 */
void executeITensor(
    std::unique_ptr<zdl::SNPE::SNPE>& snpe,
    std::unique_ptr<zdl::DlSystem::ITensor>& input,
    const std::string& outputDir,
    int num) {

    zdl::DlSystem::TensorMap outputTensorMap;
    snpe->execute(input.get(), outputTensorMap);

    auto tensorNames = outputTensorMap.getTensorNames();
    std::for_each(tensorNames.begin(), tensorNames.end(), [&](const char* name) {
        std::ostringstream path;
        path << outputDir << "/Result_" << num << "/" << name << ".raw";
        auto tensorPtr = outputTensorMap.getTensor(name);
        size_t size = 0;
        for (auto it = tensorPtr->cbegin(); it != tensorPtr->cend(); ++it) size++;
        std::vector<float> data(size);
        std::copy(tensorPtr->cbegin(), tensorPtr->cend(), data.begin());
        saveOutput(path.str(), data.data(), data.size());
    });
}

/**
 * Execute batched input and split output — one result file per batch item.
 *
 * After executing a batched ITensor, each output tensor contains concatenated
 * results. This function splits them back into per-item result files:
 *   output/Result_{baseNum+i}/{tensor_name}.raw
 *
 * @param snpe        SNPE instance
 * @param input       Batched input tensor
 * @param outputDir   Base output directory
 * @param baseNum     Starting result index (batch_idx * batchSize)
 * @param batchSize   Number of items in the batch
 */
void executeITensorBatched(
    std::unique_ptr<zdl::SNPE::SNPE>& snpe,
    std::unique_ptr<zdl::DlSystem::ITensor>& input,
    const std::string& outputDir,
    int baseNum,
    size_t batchSize) {

    zdl::DlSystem::TensorMap outputTensorMap;
    snpe->execute(input.get(), outputTensorMap);

    auto tensorNames = outputTensorMap.getTensorNames();
    std::for_each(tensorNames.begin(), tensorNames.end(), [&](const char* name) {
        auto tensorPtr = outputTensorMap.getTensor(name);

        // Calculate per-item chunk size by dividing total by batch size
        size_t totalSize = 0;
        for (auto it = tensorPtr->cbegin(); it != tensorPtr->cend(); ++it) totalSize++;
        size_t batchChunk = totalSize / batchSize;

        // Copy full tensor to flat buffer
        std::vector<float> allData(totalSize);
        std::copy(tensorPtr->cbegin(), tensorPtr->cend(), allData.begin());

        // Write one result file per batch item
        for (size_t i = 0; i < batchSize; i++) {
            std::ostringstream path;
            path << outputDir << "/Result_" << (baseNum + static_cast<int>(i))
                 << "/" << name << ".raw";
            saveOutput(path.str(),
                       allData.data() + i * batchChunk,
                       batchChunk);
        }
    });
}
