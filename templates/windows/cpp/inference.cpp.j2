/**
 * QNN C++ Inference Application — Windows on Snapdragon
 *
 * Auto-generated by QUAD (Qualcomm Unified Agent for Developers).
 * SDK:     {{ sdk | default('QNN') }}
 * Model:   {{ model_path }}
 * Runtime: {{ runtime | default('NPU (Hexagon HTP)') }}
 *
 * Pipeline (from quad.qnn.inference_pipeline.SO_PIPELINE_STEPS):
 *   1. Load backend library (libQnnHtp.dll for NPU / libQnnCpu.dll for CPU)
 *   2. Resolve QnnInterface via QnnInterface_getProviders
 *   3. Initialise QnnLog -> QnnBackend -> QnnDevice -> QnnContext
 *   4. Load model: either compose-from-.so OR deserialize-from-.bin
 *   5. Iterate inputs/outputs, allocate Qnn_Tensor_t buffers, populate
 *      from input.raw files
 *   6. QnnGraph_execute, then dump outputs to <name>.raw files
 *   7. Cleanup in reverse order
 *
 * Build:  cmake -B build -S . && cmake --build build --config Release
 * Run:    .\build\inference.exe <input.raw> [--output-dir <dir>]
 */

