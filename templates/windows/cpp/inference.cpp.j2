#ifdef _WIN32
#  include <windows.h>
   typedef HMODULE LibHandle;
#  define QUAD_LOAD_LIB(p)        LoadLibraryA((p))
#  define QUAD_GET_SYM(h, n)      ((void *)GetProcAddress((h), (n)))
#  define QUAD_FREE_LIB(h)        FreeLibrary((h))
#  define QUAD_LIB_ERROR()        ::std::to_string(::GetLastError())
#else
#  include <dlfcn.h>
   typedef void *LibHandle;
#  define QUAD_LOAD_LIB(p)        dlopen((p), RTLD_NOW)
#  define QUAD_GET_SYM(h, n)      dlsym((h), (n))
#  define QUAD_FREE_LIB(h)        dlclose((h))
#  define QUAD_LIB_ERROR()        ::std::string(dlerror() ? dlerror() : "unknown")
#endif

// QNN SDK headers — these come from the QAIRT SDK include path.
// CMakeLists.txt sets QAIRT_SDK_ROOT and propagates it to compilation.
#include "QnnInterface.h"
