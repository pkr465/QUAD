#ifndef QUAD_QNN_BACKEND_LIB
#  define QUAD_QNN_BACKEND_LIB "QnnHtp.dll"
#endif

namespace {

// ─── Utility: read/write .raw files ─────────────────────────────────────────
std::vector<uint8_t> read_raw_file(const std::string& path) {
    std::ifstream f(path, std::ios::binary | std::ios::ate);
    if (!f) {
        throw std::runtime_error("Cannot open input file: " + path);
    }
    const auto sz = static_cast<std::streamsize>(f.tellg());
    f.seekg(0);
    std::vector<uint8_t> buf(sz);
    f.read(reinterpret_cast<char*>(buf.data()), sz);
    return buf;
}

void write_raw_file(const std::string& path, const void* data, size_t bytes) {
    std::ofstream f(path, std::ios::binary);
    if (!f) {
        throw std::runtime_error("Cannot open output file: " + path);
    }
    f.write(reinterpret_cast<const char*>(data), static_cast<std::streamsize>(bytes));
}

// ─── QnnLog callback ────────────────────────────────────────────────────────
void qnn_log_callback(const char* fmt, QnnLog_Level_t level, uint64_t timestamp, va_list argp) {
    static const char* level_str[] = {"ERROR", "WARN", "INFO", "DEBUG", "VERBOSE"};
    fprintf(stderr, "[QNN %s] ", level_str[level <= 4 ? level : 0]);
    vfprintf(stderr, fmt, argp);
    fprintf(stderr, "\n");
}

// ─── QNN backend wrapper ────────────────────────────────────────────────────
class QnnInferenceEngine {
public:
    QnnInferenceEngine(std::string model_path, std::string backend_lib)
        : model_path_(std::move(model_path)), backend_lib_(std::move(backend_lib)) {}

    ~QnnInferenceEngine() { cleanup(); }

    void initialize() {
        // Step 1+2: load backend library + resolve interface
        backend_handle_ = QUAD_LOAD_LIB(backend_lib_.c_str());
        if (!backend_handle_) {
            throw std::runtime_error("Failed to load " + backend_lib_ + ": " + QUAD_LIB_ERROR());
        }
        std::cout << "[QUAD] Loaded backend: " << backend_lib_ << std::endl;

        using QnnInterface_getProviders_fn_t =
            Qnn_ErrorHandle_t(*)(const QnnInterface_t***, uint32_t*);
        auto get_providers = reinterpret_cast<QnnInterface_getProviders_fn_t>(
            QUAD_GET_SYM(backend_handle_, "QnnInterface_getProviders"));
        if (!get_providers) {
            throw std::runtime_error("QnnInterface_getProviders not exported by backend");
        }

        const QnnInterface_t** providers = nullptr;
        uint32_t num_providers = 0;
        if (get_providers(&providers, &num_providers) != QNN_SUCCESS || num_providers == 0) {
            throw std::runtime_error("QnnInterface_getProviders returned no providers");
        }
        // Pick the first matching provider (production code would
        // version-check against QNN_API_VERSION_MAJOR/MINOR/PATCH).
        qnn_interface_ = providers[0]->QNN_INTERFACE_VER_NAME;
        std::cout << "[QUAD] Resolved QNN interface from provider 0/" << num_providers << std::endl;

        // Step 3: log -> backend -> device -> context
        if (qnn_interface_.logCreate(qnn_log_callback, QNN_LOG_LEVEL_INFO, &log_handle_) != QNN_SUCCESS) {
            throw std::runtime_error("QnnLog_create failed");
        }
        if (qnn_interface_.backendCreate(log_handle_, nullptr, &backend_handle_qnn_) != QNN_SUCCESS) {
            throw std::runtime_error("QnnBackend_create failed");
        }
        if (qnn_interface_.deviceCreate(log_handle_, nullptr, &device_handle_) != QNN_SUCCESS) {
            throw std::runtime_error("QnnDevice_create failed");
        }
        if (qnn_interface_.contextCreate(backend_handle_qnn_, device_handle_, nullptr, &context_handle_) != QNN_SUCCESS) {
            throw std::runtime_error("QnnContext_create failed");
        }
        std::cout << "[QUAD] QNN runtime initialised" << std::endl;
    }

    void load_model() {
        // Step 4: deserialise context binary (.bin) if the model path
        // ends with .bin; otherwise delegate to the .so loader.
        const auto dot = model_path_.find_last_of('.');
        const auto ext = (dot == std::string::npos) ? "" : model_path_.substr(dot);

        if (ext == ".bin") {
            auto bin = read_raw_file(model_path_);
            if (qnn_interface_.contextCreateFromBinary(
                    backend_handle_qnn_,
                    device_handle_,
                    nullptr,
                    bin.data(),
                    bin.size(),
                    &context_handle_,
                    nullptr) != QNN_SUCCESS) {
                throw std::runtime_error("QnnContext_createFromBinary failed");
            }
            // Retrieve all graphs in the context
            uint32_t num_graphs = 0;
            Qnn_GraphHandle_t* graphs = nullptr;
            if (qnn_interface_.contextGetGraphHandles(context_handle_, &graphs, &num_graphs) != QNN_SUCCESS
                || num_graphs == 0) {
                throw std::runtime_error("Context has no graphs after binary load");
            }
            graph_ = graphs[0];
        } else if (ext == ".so" || ext == ".dll") {
            // Compose-from-shared-library path: dlopen the model's .so,
            // resolve QnnModel_composeGraphs, build the graph, finalize.
            // This is a more advanced path; see
            // quad.qnn.inference_pipeline for the full sequence.
            throw std::runtime_error(
                "Model format '" + ext + "' (compose-from-.so) requires the full pipeline; "
                "convert to .bin via 'quad convert_model' or qnn-context-binary-generator.");
        } else {
            throw std::runtime_error("Unsupported model extension: " + ext + " (need .bin)");
        }
        std::cout << "[QUAD] Model loaded: " << model_path_ << std::endl;
    }

    // Run a single inference. inputs / outputs are .raw file paths
    // referenced from the input_list.txt format that snpe-net-run uses.
    void run(const std::map<std::string, std::string>& inputs,
             const std::string& output_dir) {
        // Discover graph I/O schema
        Qnn_Tensor_t* input_tensors = nullptr;
        Qnn_Tensor_t* output_tensors = nullptr;
        uint32_t num_inputs = 0, num_outputs = 0;
        if (qnn_interface_.graphGetInputTensors(graph_, &input_tensors, &num_inputs) != QNN_SUCCESS
            || qnn_interface_.graphGetOutputTensors(graph_, &output_tensors, &num_outputs) != QNN_SUCCESS) {
            throw std::runtime_error("Failed to inspect graph I/O schema");
        }

        // Populate inputs from the .raw files
        std::vector<std::vector<uint8_t>> input_buffers(num_inputs);
        for (uint32_t i = 0; i < num_inputs; ++i) {
            const auto* tname = QNN_TENSOR_GET_NAME(&input_tensors[i]);
            auto it = inputs.find(tname);
            const std::string path = (it != inputs.end())
                ? it->second
                : (inputs.size() == 1 ? inputs.begin()->second : "");
            if (path.empty()) {
                throw std::runtime_error(std::string("No input file for tensor: ") + tname);
            }
            input_buffers[i] = read_raw_file(path);
            QNN_TENSOR_SET_CLIENT_BUF(
                &input_tensors[i],
                Qnn_ClientBuffer_t{ input_buffers[i].data(),
                                    static_cast<uint32_t>(input_buffers[i].size()) });
        }

        // Allocate output buffers
        std::vector<std::vector<uint8_t>> output_buffers(num_outputs);
        for (uint32_t i = 0; i < num_outputs; ++i) {
            const auto* dims = QNN_TENSOR_GET_DIMENSIONS(&output_tensors[i]);
            const uint32_t rank = QNN_TENSOR_GET_RANK(&output_tensors[i]);
            uint32_t numel = 1;
            for (uint32_t r = 0; r < rank; ++r) numel *= dims[r];
            const auto dtype = QNN_TENSOR_GET_DATA_TYPE(&output_tensors[i]);
            const uint32_t bytes_per_elem = qnn_dtype_bytes(dtype);
            output_buffers[i].resize(static_cast<size_t>(numel) * bytes_per_elem);
            QNN_TENSOR_SET_CLIENT_BUF(
                &output_tensors[i],
                Qnn_ClientBuffer_t{ output_buffers[i].data(),
                                    static_cast<uint32_t>(output_buffers[i].size()) });
        }

        // Step 6: execute
        if (qnn_interface_.graphExecute(
                graph_,
                input_tensors, num_inputs,
                output_tensors, num_outputs,
                nullptr, nullptr) != QNN_SUCCESS) {
            throw std::runtime_error("QnnGraph_execute failed");
        }
        std::cout << "[QUAD] Inference complete" << std::endl;

        // Write outputs to output_dir/<tensor_name>.raw
        for (uint32_t i = 0; i < num_outputs; ++i) {
            const auto* tname = QNN_TENSOR_GET_NAME(&output_tensors[i]);
            const std::string out_path = output_dir + "/" + tname + ".raw";
            write_raw_file(out_path, output_buffers[i].data(), output_buffers[i].size());
            std::cout << "[QUAD] Wrote " << out_path
                      << " (" << output_buffers[i].size() << " bytes)" << std::endl;
        }
    }

    void cleanup() {
        // Step 7: free in reverse order. Each call is best-effort —
        // we don't want one failed teardown to mask another.
        if (context_handle_ && qnn_interface_.contextFree) {
            qnn_interface_.contextFree(context_handle_, nullptr);
            context_handle_ = nullptr;
        }
        if (device_handle_ && qnn_interface_.deviceFree) {
            qnn_interface_.deviceFree(device_handle_);
            device_handle_ = nullptr;
        }
        if (backend_handle_qnn_ && qnn_interface_.backendFree) {
            qnn_interface_.backendFree(backend_handle_qnn_);
            backend_handle_qnn_ = nullptr;
        }
        if (log_handle_ && qnn_interface_.logFree) {
            qnn_interface_.logFree(log_handle_);
            log_handle_ = nullptr;
        }
        if (backend_handle_) {
            QUAD_FREE_LIB(backend_handle_);
            backend_handle_ = nullptr;
        }
    }

private:
    static uint32_t qnn_dtype_bytes(Qnn_DataType_t dt) {
        switch (dt) {
            case QNN_DATATYPE_FLOAT_32: return 4;
            case QNN_DATATYPE_FLOAT_16: return 2;
            case QNN_DATATYPE_INT_64:   return 8;
            case QNN_DATATYPE_INT_32:   return 4;
            case QNN_DATATYPE_INT_16:   return 2;
            case QNN_DATATYPE_INT_8:    return 1;
            case QNN_DATATYPE_UINT_32:  return 4;
            case QNN_DATATYPE_UINT_16:  return 2;
            case QNN_DATATYPE_UINT_8:   return 1;
            case QNN_DATATYPE_BOOL_8:   return 1;
            default:                    return 4;
        }
    }

    std::string model_path_;
    std::string backend_lib_;
    LibHandle backend_handle_ = nullptr;
    QNN_INTERFACE_VER_TYPE qnn_interface_{};
    Qnn_LogHandle_t log_handle_ = nullptr;
    Qnn_BackendHandle_t backend_handle_qnn_ = nullptr;
    Qnn_DeviceHandle_t device_handle_ = nullptr;
    Qnn_ContextHandle_t context_handle_ = nullptr;
    Qnn_GraphHandle_t graph_ = nullptr;
};

}  // namespace

int main(int argc, char* argv[]) {
    const std::string model_path = "{{ model_path }}";
    const std::string backend_lib = QUAD_QNN_BACKEND_LIB;

    if (argc < 2) {
        std::cerr << "Usage: " << argv[0] << " <input.raw> [--output-dir <dir>]" << std::endl;
        std::cerr << "  Model: " << model_path << std::endl;
        std::cerr << "  Backend: " << backend_lib << std::endl;
        return 2;
    }

    std::map<std::string, std::string> inputs;
    inputs["{{ input_name | default('input') }}"] = argv[1];
    std::string output_dir = ".";
    for (int i = 2; i + 1 < argc; ++i) {
        if (std::string(argv[i]) == "--output-dir") output_dir = argv[i + 1];
    }

    try {
        QnnInferenceEngine engine(model_path, backend_lib);
        engine.initialize();
        engine.load_model();
        engine.run(inputs, output_dir);
    } catch (const std::exception& e) {
        std::cerr << "[QUAD ERROR] " << e.what() << std::endl;
        return 1;
    }
    return 0;
}
