# QUAD Environment Variables — Example File
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env — it contains secrets.
# This .env.example IS committed as a reference template.

# ── Qualcomm AI Hub ──────────────────────────────────────────────────────────
# Get your API key at: https://app.aihub.qualcomm.com
QAI_HUB_API_KEY=

# ── QAIRT / SNPE / QNN SDK paths ─────────────────────────────────────────────
# Set these if you don't want to use quad.toml for SDK paths.
# Usually only one of these is needed (they often point to the same directory).
QAIRT_SDK_ROOT=
QNN_SDK_ROOT=
SNPE_ROOT=

# ── Hexagon SDK ───────────────────────────────────────────────────────────────
HEXAGON_SDK_ROOT=
HEXAGON_TOOLS_ROOT=

# ── Android NDK (for UDO compilation) ────────────────────────────────────────
ANDROID_NDK_ROOT=

# ── DSP Runtime Library Path ─────────────────────────────────────────────────
# Required for HTP/DSP execution. Separate multiple paths with semicolons.
# Example: /opt/qairt/2.45.0/lib/aarch64-android;/vendor/lib/rfsa/adsp
ADSP_LIBRARY_PATH=

# ── Target Device: Linux (SSH) ───────────────────────────────────────────────
TARGET_IP=
TARGET_USER=root
TARGET_SSH_KEY=~/.ssh/id_rsa
# Valid values: android | linux | automotive
TARGET_OS=

# ── Target Device: Android (ADB) ─────────────────────────────────────────────
# Leave blank to auto-select the connected device
ANDROID_SERIAL=

# ── QUAD Runtime Overrides ───────────────────────────────────────────────────
# These override quad.toml settings (useful in CI/CD pipelines)
# Valid values: mock | real
QUAD_ADAPTER_MODE=
# Valid values: debug | info | warning | error
QUAD_LOG_LEVEL=
